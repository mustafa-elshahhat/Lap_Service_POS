<Application x:Class="AlJohary.ServiceHub.Presentation.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:AlJohary.ServiceHub.Presentation.Helpers"
             xmlns:services="clr-namespace:AlJohary.ServiceHub.Application.Services"
             xmlns:converters="clr-namespace:AlJohary.ServiceHub.Presentation.Converters"
             ShutdownMode="OnLastWindowClose">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Presentation/Resources/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <converters:EqualityConverter x:Key="EqualityConverter"/>
            <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
            <converters:FlexibleNumberConverter x:Key="FlexibleNumberConverter"/>
            <converters:FlexibleCurrencyConverter x:Key="FlexibleCurrencyConverter"/>
            <converters:SearchEmptyStateConverter x:Key="SearchEmptyStateConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
