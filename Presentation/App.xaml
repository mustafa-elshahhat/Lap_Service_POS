<Application x:Class="CarPartsShopWPF.Presentation.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:CarPartsShopWPF.Presentation.Helpers"
             xmlns:services="clr-namespace:CarPartsShopWPF.Application.Services"
             xmlns:converters="clr-namespace:CarPartsShopWPF.Presentation.Converters"
             ShutdownMode="OnLastWindowClose">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Presentation/Resources/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <converters:EqualityConverter x:Key="EqualityConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
