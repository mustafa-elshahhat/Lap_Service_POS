<Window x:Class="AlJohary.ServiceHub.Presentation.Views.CustomerInvoicesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:AlJohary.ServiceHub.Presentation.Converters"
        Title="فواتير العميل"
        Width="900" Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FlowDirection="RightToLeft"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <converters:SaleTypeConverter x:Key="SaleTypeConverter"/>
            <converters:InvoiceStatusTextConverter x:Key="InvoiceStatusTextConverter"/>
            <converters:InvoiceStatusColorConverter x:Key="InvoiceStatusColorConverter"/>
            <converters:InvoiceStatusTextColorConverter x:Key="InvoiceStatusTextColorConverter"/>
        </ResourceDictionary>
    </Window.Resources>

    <Border Style="{DynamicResource StandardWindowContentBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> 
                <RowDefinition Height="*"/>    
                <RowDefinition Height="Auto"/> 
            </Grid.RowDefinitions>

            
            <Border Grid.Row="0" 
                    Background="{DynamicResource BgCardBrush}" 
                    BorderBrush="{DynamicResource BorderBrush}" 
                    BorderThickness="0,0,0,1" 
                    Padding="24,20" 
                    CornerRadius="16,16,0,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <TextBlock Text="🧾" FontSize="22" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="فواتير العميل"
                                       FontFamily="{DynamicResource MainFontSemibold}"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="{Binding CustomerNameHeader}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                <TextBlock Text=" • " Foreground="{DynamicResource TextMutedBrush}"/>
                                <TextBlock Text="{Binding SalesCountText}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <Button Style="{DynamicResource CloseButton}" 
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> 
                    <RowDefinition Height="*"/>    
                </Grid.RowDefinitions>
                
                
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>     
                        <ColumnDefinition Width="Auto"/>  
                    </Grid.ColumnDefinitions>
                    
                    <TextBox x:Name="SearchBox" 
                             Grid.Column="0" 
                             Style="{DynamicResource SearchTextBoxStyle}"
                             Tag="بحث برقم الفاتورة..."
                             MaxWidth="400"
                             HorizontalAlignment="Left"
                             Width="350"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock Text="النوع:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <ComboBox x:Name="FilterType" 
                                  Style="{DynamicResource MainComboBox}"
                                  Width="140"
                                  SelectionChanged="FilterType_SelectionChanged">
                            <ComboBoxItem Content="الكل" IsSelected="True"/>
                            <ComboBoxItem Content="كاش" Tag="cash"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                
                <DataGrid x:Name="InvoicesGrid" 
                          Grid.Row="1" 
                          Style="{DynamicResource DialogDataGrid}" 
                          IsReadOnly="True"
                          ItemsSource="{Binding Invoices}"
                          SelectedItem="{Binding SelectedInvoice}"
                          MouseDoubleClick="InvoicesGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding Id}" Width="50" ElementStyle="{DynamicResource DataGridTextCenter}"/>
                        <DataGridTemplateColumn Header="رقم الفاتورة" Width="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid Background="Transparent">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding InvoiceNumber}" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center" FlowDirection="LeftToRight"/>
                                        <Button Grid.Column="1" Margin="8,0,0,0" Padding="4" 
                                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                Visibility="Collapsed" x:Name="CopyBtn"
                                                Command="{Binding DataContext.CopyTextCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding InvoiceNumber}"
                                                ToolTip="نسخ">
                                            <Viewbox Width="14" Height="14">
                                                <Path Data="M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z" 
                                                      Fill="{DynamicResource TextMutedBrush}"/>
                                            </Viewbox>
                                        </Button>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="CopyBtn" Property="Visibility" Value="Visible"/>
                                        </Trigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        
                        <DataGridTextColumn Header="التاريخ" Binding="{Binding SaleDate, StringFormat=yyyy/MM/dd}" Width="120"/>
                        
                        <DataGridTextColumn Header="النوع" Binding="{Binding SaleType, Converter={StaticResource SaleTypeConverter}}" Width="100"/>

                        <DataGridTextColumn Header="الإجمالي" Binding="{Binding TotalAmount, Converter={StaticResource FlexibleNumberConverter}}" Width="110" FontWeight="Bold"/>

                        <DataGridTextColumn Header="المدفوع" Binding="{Binding PaidAmount, Converter={StaticResource FlexibleNumberConverter}}" Width="110" Foreground="{DynamicResource SecondaryBrush}"/>

                        <DataGridTextColumn Header="المتبقي" Binding="{Binding RemainingAmount, Converter={StaticResource FlexibleNumberConverter}}" Width="110" Foreground="{DynamicResource WarningDarkBrush}" FontWeight="SemiBold"/>
                        
                        <DataGridTemplateColumn Header="الحالة" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="6" 
                                            Padding="10,4" 
                                            HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"
                                            Background="{Binding Converter={StaticResource InvoiceStatusColorConverter}}">
                                        <TextBlock Text="{Binding Converter={StaticResource InvoiceStatusTextConverter}}" 
                                                   Foreground="{Binding Converter={StaticResource InvoiceStatusTextColorConverter}}" 
                                                   FontSize="11" 
                                                   FontWeight="Bold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="عرض تفاصيل الفاتورة" Click="ViewDetails_Click"/>
                            <Separator/>
                            <MenuItem Header="طباعة الفاتورة" Click="Print_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>
                
                <TextBlock x:Name="EmptyStateText" 
                           Grid.Row="1" 
                           Text="لا توجد فواتير مسجلة لهذا العميل" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center" 
                           Foreground="{DynamicResource TextMutedBrush}" 
                           FontSize="15" 
                           FontWeight="Medium"
                           Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </Grid>
            
            
            <Border Grid.Row="2" 
                    Background="{DynamicResource BgMainBrush}" 
                    BorderBrush="{DynamicResource BorderBrush}" 
                    BorderThickness="0,1,0,0" 
                    Padding="20" 
                    CornerRadius="0,0,16,16">
                 <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                     <Button Style="{DynamicResource PrimaryButton}" MinWidth="160" Height="48" Margin="0,0,16,0" Click="PrintStatement_Click">
                         <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                             <Viewbox Width="18" Height="18">
                                 <Path Data="M18,3H6V7H18M19,12A1,1 0 0,1 18,11A1,1 0 0,1 19,10A1,1 0 0,1 20,11A1,1 0 0,1 19,12M16,19H8V14H16M19,8H5A3,3 0 0,0 2,11V17H6V21H18V17H22V11A3,3 0 0,0 19,8Z" 
                                       Fill="White"/>
                             </Viewbox>
                             <TextBlock Text="طباعة كشف حساب" Margin="0,0,8,0" VerticalAlignment="Center"/>
                         </StackPanel>
                     </Button>
                     <Button Content="إغلاق النافذة" Style="{DynamicResource DarkButton}" MinWidth="140" Height="48" IsCancel="True" Click="CloseButton_Click"/>
                 </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
