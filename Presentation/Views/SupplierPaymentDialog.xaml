<Window x:Class="CarPartsShopWPF.Presentation.Views.SupplierPaymentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="سداد مديونية"
        SizeToContent="WidthAndHeight"
        MinWidth="450"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        FlowDirection="RightToLeft">

    <Border Style="{DynamicResource StandardWindowContentBorder}">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="💰 سداد دفعة للمورد" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="{DynamicResource SecondaryBrush}" 
                           VerticalAlignment="Center"
                           FontFamily="{DynamicResource MainFontSemibold}"/>
                           
                <Button Style="{DynamicResource CloseButton}" 
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Click="CancelButton_Click"/>
            </Grid>

            
            <Border Grid.Row="1" Background="{DynamicResource BgCardBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <StackPanel>
                     <TextBlock Text="المورد" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding SupplierName}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="{DynamicResource MainFontSemibold}"/>
                    
                    <Separator Background="{DynamicResource BorderBrush}" Margin="0,12"/>
                    
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="المديونية الحالية: " FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding CurrentDebtText}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource WarningDarkBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            
            <Grid Grid.Row="2" Margin="0,0,0,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                
                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                    <Label Content="مبلغ السداد (الدفعة) *" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                    <TextBox x:Name="AmountTextBox" 
                             Style="{DynamicResource MainTextBox}"
                             PreviewTextInput="NumberValidationTextBox"/>
                </StackPanel>

                
                <StackPanel Grid.Row="1">
                    <Label Content="طريقة الدفع" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                    <ComboBox x:Name="PaymentMethodComboBox"
                              Style="{DynamicResource MainComboBox}"
                              SelectedIndex="0">
                        <ComboBoxItem Content="نقدي"/>
                        <ComboBoxItem Content="محافظ إلكترونية"/>
                        <ComboBoxItem Content="إنستا باي"/>
                    </ComboBox>
                </StackPanel>
            </Grid>

            
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                <Button Content="تأكيد السداد" 
                        Style="{DynamicResource SecondaryButton}" 
                        Width="140" 
                        Margin="8,0" 
                        IsDefault="True"
                        Click="SaveButton_Click"/>
                <Button Content="إلغاء" 
                        Style="{DynamicResource DarkButton}" 
                        Width="120" 
                        Margin="8,0" 
                        IsCancel="True"
                        Click="CancelButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
