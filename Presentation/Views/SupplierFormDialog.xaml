<Window x:Class="AlJohary.ServiceHub.Presentation.Views.SupplierFormDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:AlJohary.ServiceHub.Presentation.Helpers"
        Title="بيانات المورد"
        helpers:DialogChrome.DimOwner="True" 
        SizeToContent="WidthAndHeight"
        MinWidth="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FlowDirection="RightToLeft">

    <Border Style="{DynamicResource StandardWindowContentBorder}">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Button Style="{DynamicResource CloseButton}" 
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Click="CancelButton_Click"/>

                <TextBlock x:Name="TitleTextBlock" 
                            Text="{Binding Title}" 
                            FontFamily="{DynamicResource MainFontSemibold}"
                            FontSize="18" 
                            FontWeight="SemiBold" 
                            Foreground="{DynamicResource PrimaryBrush}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"/>
            </Grid>

            <StackPanel Grid.Row="1">
                <Label Content="اسم المورد (مطلوب)"/>
                <TextBox x:Name="NameTextBox" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16"/>

                <Label Content="رقم الهاتف"/>
                <TextBox x:Name="PhoneTextBox" Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16" PreviewTextInput="PhoneTextBox_PreviewTextInput"/>

                <Label Content="العنوان"/>
                <TextBox x:Name="AddressTextBox" Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" Height="80" TextWrapping="Wrap" VerticalContentAlignment="Top" Padding="12,10"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,24,0,0">
                <Button x:Name="SaveButton" Content="{Binding SaveButtonContent}" Style="{DynamicResource PrimaryButton}" MinWidth="120" Margin="8,0" IsDefault="True" Click="SaveButton_Click"/>
                <Button Content="إلغاء" Style="{DynamicResource DarkButton}" MinWidth="100" Margin="8,0" IsCancel="True" Click="CancelButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

