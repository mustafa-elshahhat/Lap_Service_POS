<Page x:Class="CarPartsShopWPF.Presentation.Views.InvoicesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="قائمة الفواتير"
      Background="{DynamicResource BgMainBrush}"
      FlowDirection="RightToLeft"
      UseLayoutRounding="True"
      SnapsToDevicePixels="True">

    <Grid Margin="16">
        <Border Background="{DynamicResource BgCardBrush}" 
                BorderBrush="{DynamicResource BorderBrush}" 
                BorderThickness="1" 
                CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="24,24,24,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    
                    <TextBlock Grid.Column="0" 
                               Text="🧾 قائمة الفواتير" 
                               FontFamily="{DynamicResource MainFontSemibold}" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>

                    
                    <Button Grid.Column="2"
                            Content="🔄 عرض الكل"
                            Style="{DynamicResource DarkButton}"
                            Width="140"
                            Command="{Binding LoadAllCommand}"/>
                </Grid>

                
                <Grid Grid.Row="1" Margin="24,0,24,16">
                     <TextBox x:Name="SearchTextBox"
                              Style="{DynamicResource SearchTextBoxStyle}"
                              Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                         <TextBox.InputBindings>
                             <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                         </TextBox.InputBindings>
                     </TextBox>
                     
                     <StackPanel Orientation="Horizontal" IsHitTestVisible="False" Margin="12,0" VerticalAlignment="Center">
                          <TextBlock Text="🔍" FontSize="16" Margin="0,0,8,0" Foreground="{DynamicResource TextMutedBrush}"/>
                          <TextBlock Text="ابحث عن فاتورة..." 
                                     Foreground="{DynamicResource TextMutedBrush}">
                              <TextBlock.Style>
                                  <Style TargetType="TextBlock">
                                      <Setter Property="Visibility" Value="Collapsed"/>
                                      <Style.Triggers>
                                          <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                              <Setter Property="Visibility" Value="Visible"/>
                                          </DataTrigger>
                                      </Style.Triggers>
                                  </Style>
                              </TextBlock.Style>
                          </TextBlock>
                     </StackPanel>
                </Grid>

                <DataGrid Grid.Row="2" 
                          Margin="24,0,24,24" 
                          Style="{DynamicResource MainDataGrid}" 
                          ItemsSource="{Binding Invoices}" 
                          SelectedItem="{Binding SelectedInvoice}"
                          IsReadOnly="True">
                    <DataGrid.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding ViewInvoiceCommand}"/>
                    </DataGrid.InputBindings>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="م" Binding="{Binding Id}" Width="Auto" ElementStyle="{DynamicResource DataGridTextCenter}"/>
                        <DataGridTemplateColumn Header="رقم الفاتورة" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid Background="Transparent">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock Text="{Binding InvoiceNumber}" 
                                                   FontWeight="SemiBold" 
                                                   VerticalAlignment="Center" 
                                                   HorizontalAlignment="Center"
                                                   FlowDirection="LeftToRight"/>
                                        
                                        
                                        <Button Grid.Column="1" Margin="8,0,0,0" Padding="4" 
                                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                Visibility="Collapsed" x:Name="CopyBtn"
                                                Command="{Binding DataContext.CopyTextCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding InvoiceNumber}"
                                                ToolTip="نسخ">
                                            <Viewbox Width="14" Height="14">
                                                <Path Data="M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z" 
                                                      Fill="{DynamicResource TextMutedBrush}"/>
                                            </Viewbox>
                                        </Button>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="CopyBtn" Property="Visibility" Value="Visible"/>
                                        </Trigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="التاريخ" Binding="{Binding SaleDate, StringFormat='yyyy-MM-dd hh:mm tt'}" Width="Auto" ElementStyle="{DynamicResource DataGridTextCenter}"/>
                        <DataGridTextColumn Header="العميل" Binding="{Binding CustomerName}" Width="*"/>
                        <DataGridTextColumn Header="المستخدم" Binding="{Binding UserName}" Width="Auto" ElementStyle="{DynamicResource DataGridTextCenter}"/>
                        <DataGridTextColumn Header="الإجمالي" Binding="{Binding TotalAmount, StringFormat=N2}" Width="Auto" ElementStyle="{DynamicResource DataGridTextCenter}"/>
                        <DataGridTextColumn Header="المدفوع" Binding="{Binding PaidAmount, StringFormat=N2}" Width="Auto" ElementStyle="{DynamicResource DataGridTextCenter}"/>
                        <DataGridTextColumn Header="المتبقي" Binding="{Binding RemainingAmount, StringFormat=N2}" Width="Auto">
                             <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridTextCenter}">
                                    <Setter Property="Foreground" Value="{DynamicResource WarningDarkBrush}"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                    
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="👁️ عرض الفاتورة" Command="{Binding ViewInvoiceCommand}"/>
                            <MenuItem Header="🖨️ طباعة" Command="{Binding PrintInvoiceCommand}"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>
