<Page x:Class="AlJohary.ServiceHub.Presentation.Views.InvoicesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="قائمة الفواتير"
      Background="{DynamicResource BgMainBrush}"
      FlowDirection="RightToLeft"
      UseLayoutRounding="True"
      SnapsToDevicePixels="True">

    <Grid Margin="{DynamicResource PageContentMargin}">
        <Border Background="{DynamicResource BgCardBrush}" 
                BorderBrush="{DynamicResource BorderBrush}" 
                BorderThickness="1" 
                CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="24,24,24,20" FlowDirection="LeftToRight">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                     
                    <Button Grid.Column="0"
                            Content="🔄 عرض الكل"
                            Style="{DynamicResource DarkButton}"
                            MinWidth="140"
                            HorizontalAlignment="Left"
                            FlowDirection="RightToLeft"
                            Command="{Binding LoadAllCommand}"/>

                    
                    <TextBlock Grid.Column="2" 
                               Text="🧾 قائمة الفواتير" 
                               FontFamily="{DynamicResource MainFontSemibold}" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Right"
                               FlowDirection="RightToLeft"
                               VerticalAlignment="Center"/>
                </Grid>

                
                <Grid Grid.Row="1" Margin="24,0,24,16">
                     <TextBox x:Name="SearchTextBox"
                              Style="{DynamicResource SearchTextBoxStyle}"
                              Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                         <TextBox.InputBindings>
                             <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                         </TextBox.InputBindings>
                     </TextBox>
                     
                     <StackPanel Orientation="Horizontal" IsHitTestVisible="False" Margin="12,0" VerticalAlignment="Center">
                          <TextBlock Text="🔍" FontSize="16" Margin="0,0,8,0" Foreground="{DynamicResource TextMutedBrush}"/>
                          <TextBlock Text="ابحث عن فاتورة..." 
                                     Foreground="{DynamicResource TextMutedBrush}">
                              <TextBlock.Style>
                                  <Style TargetType="TextBlock">
                                      <Setter Property="Visibility" Value="Collapsed"/>
                                      <Style.Triggers>
                                          <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                              <Setter Property="Visibility" Value="Visible"/>
                                          </DataTrigger>
                                      </Style.Triggers>
                                  </Style>
                              </TextBlock.Style>
                          </TextBlock>
                     </StackPanel>
                </Grid>

                <Grid Grid.Row="2" Margin="24,0,24,24">
                <DataGrid x:Name="InvoicesGrid"
                          Style="{DynamicResource MainDataGrid}"
                          ItemsSource="{Binding Invoices}"
                          SelectedItem="{Binding SelectedInvoice}"
                          IsReadOnly="True"
                          HorizontalScrollBarVisibility="Auto">
                    <DataGrid.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding ViewInvoiceCommand}"/>
                    </DataGrid.InputBindings>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="م" Binding="{Binding Id}" Width="60" MinWidth="50" ElementStyle="{DynamicResource DataGridTextCenter}"/>
                        <DataGridTemplateColumn Header="رقم الفاتورة" Width="150" MinWidth="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid Background="Transparent">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock Text="{Binding InvoiceNumber}" 
                                                   FontWeight="SemiBold" 
                                                   VerticalAlignment="Center" 
                                                   HorizontalAlignment="Center"
                                                   FlowDirection="LeftToRight"/>
                                        
                                        
                                        <Button Grid.Column="1" Margin="8,0,0,0" Padding="4" 
                                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                Visibility="Collapsed" x:Name="CopyBtn"
                                                Command="{Binding DataContext.CopyTextCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding InvoiceNumber}"
                                                ToolTip="نسخ">
                                            <Viewbox Width="14" Height="14">
                                                <Path Data="M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z" 
                                                      Fill="{DynamicResource TextMutedBrush}"/>
                                            </Viewbox>
                                        </Button>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="CopyBtn" Property="Visibility" Value="Visible"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                            <Setter TargetName="CopyBtn" Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="التاريخ" Binding="{Binding SaleDate, StringFormat='yyyy-MM-dd hh:mm tt'}" Width="160" MinWidth="150" ElementStyle="{DynamicResource DataGridTextCenter}"/>
                        <DataGridTextColumn Header="العميل" Binding="{Binding CustomerName}" Width="*" MinWidth="160"/>
                        <DataGridTextColumn Header="الإجمالي" Binding="{Binding TotalAmount, Converter={StaticResource FlexibleNumberConverter}}" Width="110" MinWidth="90" ElementStyle="{DynamicResource DataGridTextNumeric}"/>
                        <DataGridTextColumn Header="المدفوع" Binding="{Binding PaidAmount, Converter={StaticResource FlexibleNumberConverter}}" Width="110" MinWidth="90" ElementStyle="{DynamicResource DataGridTextNumeric}"/>
                        <DataGridTextColumn Header="المتبقي" Binding="{Binding RemainingAmount, Converter={StaticResource FlexibleNumberConverter}}" Width="110" MinWidth="90">
                             <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridTextNumeric}">
                                    <Setter Property="Foreground" Value="{DynamicResource WarningDarkBrush}"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="المستخدم" Binding="{Binding UserName}" Width="120" MinWidth="100" ElementStyle="{DynamicResource DataGridTextCenter}"/>
                    </DataGrid.Columns>
                    
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="👁️ عرض الفاتورة" Command="{Binding ViewInvoiceCommand}"/>
                            <MenuItem Header="🖨️ طباعة" Command="{Binding PrintInvoiceCommand}"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>
                <TextBlock Style="{DynamicResource DataGridEmptyState}" Text="لا توجد فواتير للعرض">
                    <TextBlock.Visibility>
                        <MultiBinding Converter="{StaticResource SearchEmptyStateConverter}" ConverterParameter="NoData">
                            <Binding Path="HasItems" ElementName="InvoicesGrid"/>
                            <Binding Path="SearchText"/>
                        </MultiBinding>
                    </TextBlock.Visibility>
                </TextBlock>
                <TextBlock Style="{DynamicResource DataGridEmptyState}" Text="لا توجد نتائج مطابقة للبحث">
                    <TextBlock.Visibility>
                        <MultiBinding Converter="{StaticResource SearchEmptyStateConverter}" ConverterParameter="NoResults">
                            <Binding Path="HasItems" ElementName="InvoicesGrid"/>
                            <Binding Path="SearchText"/>
                        </MultiBinding>
                    </TextBlock.Visibility>
                </TextBlock>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
