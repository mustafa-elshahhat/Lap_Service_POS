<Page x:Class="CarPartsShopWPF.Presentation.Views.MaintenancePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="الصيانة"
      Background="{DynamicResource BgMainBrush}"
      FlowDirection="RightToLeft"
      UseLayoutRounding="True"
      SnapsToDevicePixels="True">

    <Grid Margin="16">
        <Border Background="{DynamicResource BgCardBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="24,24,24,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="🔧 إدارة الصيانة والإصلاح"
                               FontFamily="{DynamicResource MainFontSemibold}"
                               FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="➕ طلب جديد"
                                Style="{DynamicResource PrimaryButton}"
                                Width="130" Margin="4,0"
                                Command="{Binding NewOrderCommand}"/>
                        <Button Content="✅ تسليم"
                                Style="{DynamicResource SuccessButton}"
                                Width="100" Margin="4,0"
                                Command="{Binding DeliverOrderCommand}"/>
                        <Button Content="🖨 استلام"
                                Style="{DynamicResource InfoButton}"
                                Width="100" Margin="4,0"
                                Command="{Binding PrintIntakeCommand}"/>
                        <Button Content="🧾 فاتورة"
                                Style="{DynamicResource SecondaryButton}"
                                Width="100" Margin="4,0"
                                Command="{Binding PrintInvoiceCommand}"/>
                        <Button Content="❌ إلغاء"
                                Style="{DynamicResource DangerButton}"
                                Width="90" Margin="4,0"
                                Command="{Binding CancelOrderCommand}"/>
                        <Button Content="↺"
                                Style="{DynamicResource DarkButton}"
                                Width="45" Margin="4,0"
                                FontSize="18"
                                ToolTip="تحديث"
                                Command="{Binding RefreshCommand}"/>
                    </StackPanel>
                </Grid>

                <!-- Filters -->
                <Grid Grid.Row="1" Margin="24,0,24,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <TextBox x:Name="SearchTextBox"
                                 Style="{DynamicResource SearchTextBoxStyle}"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                        <StackPanel Orientation="Horizontal" IsHitTestVisible="False"
                                    Margin="12,0" VerticalAlignment="Center">
                            <TextBlock Text="🔍" FontSize="16" Margin="0,0,8,0"
                                       Foreground="{DynamicResource TextMutedBrush}"/>
                            <TextBlock Text="ابحث برقم الطلب أو اسم العميل..."
                                       Foreground="{DynamicResource TextMutedBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Column="2">
                        <Label Content="تصفية بالحالة" Padding="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding StatusFiltersAr}"
                                  SelectedItem="{Binding StatusFilterAr}"/>
                    </StackPanel>
                </Grid>

                <!-- DataGrid -->
                <DataGrid Grid.Row="2"
                          Style="{DynamicResource MainDataGrid}"
                          Margin="24,0,24,0"
                          ItemsSource="{Binding Orders}"
                          SelectedItem="{Binding SelectedOrder}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False">
                    <DataGrid.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding OpenOrderCommand}"/>
                    </DataGrid.InputBindings>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="رقم الطلب"      Binding="{Binding OrderNumber}"            Width="140"/>
                        <DataGridTextColumn Header="العميل"          Binding="{Binding CustomerName}"           Width="*"/>
                        <DataGridTextColumn Header="الهاتف"          Binding="{Binding CustomerPhone}"          Width="110"/>
                        <DataGridTextColumn Header="الفني"           Binding="{Binding TechnicianName}"         Width="100"/>
                        <DataGridTextColumn Header="الأجهزة"         Binding="{Binding DeviceCount}"            Width="60"/>
                        <DataGridTextColumn Header="الإجمالي"        Binding="{Binding TotalAmount, StringFormat=N2}"    Width="90"/>
                        <DataGridTextColumn Header="المدفوع"         Binding="{Binding PaidAmount, StringFormat=N2}"     Width="90"/>
                        <DataGridTextColumn Header="المتبقي"         Binding="{Binding RemainingAmount, StringFormat=N2}" Width="90"/>
                        <DataGridTemplateColumn Header="الحالة"      Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="6,2"
                                            HorizontalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource InfoBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding OrderStatusColor}" Value="Success">
                                                        <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding OrderStatusColor}" Value="Danger">
                                                        <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding OrderStatusColor}" Value="Warning">
                                                        <Setter Property="Background" Value="{DynamicResource WarningBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding OrderStatusColor}" Value="Primary">
                                                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding OrderStatusAr}"
                                                   Foreground="White" FontSize="11"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="تاريخ الاستلام"  Binding="{Binding IntakeDate}"             Width="100"/>
                        <DataGridTextColumn Header="التسليم المتوقع" Binding="{Binding ExpectedDelivery}"       Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Status bar -->
                <Grid Grid.Row="3" Margin="24,8,24,16">
                    <TextBlock Foreground="{DynamicResource TextMutedBrush}" FontSize="12"
                               VerticalAlignment="Center">
                        <Run Text="عدد الطلبات: "/>
                        <Run Text="{Binding Orders.Count, Mode=OneWay}"/>
                        <Run Text="  |  انقر نقراً مزدوجاً لفتح الطلب"/>
                    </TextBlock>
                </Grid>

            </Grid>
        </Border>
    </Grid>
</Page>
