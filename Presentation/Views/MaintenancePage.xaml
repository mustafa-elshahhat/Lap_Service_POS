<Page x:Class="AlJohary.ServiceHub.Presentation.Views.MaintenancePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="الصيانة"
      Background="{DynamicResource BgMainBrush}"
      FlowDirection="RightToLeft"
      UseLayoutRounding="True"
      SnapsToDevicePixels="True">

    <Grid Margin="16">
        <Border Background="{DynamicResource BgCardBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="24,24,24,12" FlowDirection="LeftToRight">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <WrapPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" FlowDirection="RightToLeft">
                        <Button Content="➕ طلب جديد"
                                Style="{DynamicResource PrimaryButton}"
                                MinWidth="130" Margin="4,0"
                                Command="{Binding NewOrderCommand}"/>
                        <Button Content="✅ تسليم"
                                Style="{DynamicResource SuccessButton}"
                                MinWidth="100" Margin="4,0"
                                Command="{Binding DeliverOrderCommand}"/>
                        <Button Content="🖨 استلام"
                                Style="{DynamicResource InfoButton}"
                                MinWidth="100" Margin="4,0"
                                Command="{Binding PrintIntakeCommand}"/>
                        <Button Content="🧾 فاتورة"
                                Style="{DynamicResource SecondaryButton}"
                                MinWidth="100" Margin="4,0"
                                Command="{Binding PrintInvoiceCommand}"/>
                        <Button Content="❌ إلغاء"
                                Style="{DynamicResource DangerButton}"
                                MinWidth="90" Margin="4,0"
                                Command="{Binding CancelOrderCommand}"/>
                        <Button Content="↺"
                                Style="{DynamicResource DarkButton}"
                                MinWidth="45" Margin="4,0"
                                FontSize="18"
                                ToolTip="تحديث"
                                Command="{Binding RefreshCommand}"/>
                    </WrapPanel>

                    <TextBlock Grid.Column="2"
                               Text="🔧 إدارة الصيانة والإصلاح"
                               FontFamily="{DynamicResource MainFontSemibold}"
                               FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Right"
                               FlowDirection="RightToLeft"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- Filters -->
                <Grid Grid.Row="1" Margin="24,0,24,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <TextBox x:Name="SearchTextBox"
                                 Style="{DynamicResource SearchTextBoxStyle}"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                        <StackPanel Orientation="Horizontal" IsHitTestVisible="False"
                                    Margin="12,0" VerticalAlignment="Center">
                            <TextBlock Text="🔍" FontSize="16" Margin="0,0,8,0"
                                       Foreground="{DynamicResource TextMutedBrush}"/>
                            <TextBlock Text="ابحث برقم الطلب أو اسم العميل..."
                                       Foreground="{DynamicResource TextMutedBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Column="2">
                        <Label Content="تصفية بالحالة" Padding="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding StatusFiltersAr}"
                                  SelectedItem="{Binding StatusFilterAr}"/>
                    </StackPanel>
                </Grid>

                <!-- DataGrid -->
                <Grid Grid.Row="2" Margin="24,0,24,0">
                    <DataGrid x:Name="MaintenanceGrid"
                              Style="{DynamicResource MainDataGrid}"
                              ItemsSource="{Binding Orders}"
                              SelectedItem="{Binding SelectedOrder}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False">
                        <DataGrid.InputBindings>
                            <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding OpenOrderCommand}"/>
                        </DataGrid.InputBindings>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="رقم الطلب" Binding="{Binding OrderNumber}" Width="100" MinWidth="80" ElementStyle="{DynamicResource DataGridCodeStyle}"/>
                            <DataGridTemplateColumn Header="الحالة" Width="100" MinWidth="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="4" Padding="6,2"
                                                HorizontalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource InfoBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding OrderStatusColor}" Value="Success">
                                                            <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding OrderStatusColor}" Value="Danger">
                                                            <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding OrderStatusColor}" Value="Warning">
                                                            <Setter Property="Background" Value="{DynamicResource WarningBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding OrderStatusColor}" Value="Primary">
                                                            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding OrderStatusAr}"
                                                       Foreground="White" FontSize="11"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="العميل" Binding="{Binding CustomerName}" Width="*" MinWidth="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridTextRight}">
                                        <Setter Property="ToolTip" Value="{Binding CustomerPhone, StringFormat='الهاتف: {0}'}"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="الفني" Binding="{Binding TechnicianName}" Width="100" MinWidth="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridTextCenter}">
                                        <Setter Property="ToolTip" Value="{Binding TechnicianName}"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="الأجهزة" Binding="{Binding DeviceCount}" Width="60" MinWidth="50" ElementStyle="{DynamicResource DataGridTextCenter}"/>
                            <DataGridTextColumn Header="الإجمالي" Binding="{Binding TotalAmount, Converter={StaticResource FlexibleNumberConverter}}" Width="90" MinWidth="75" ElementStyle="{DynamicResource DataGridTextNumeric}"/>
                            <DataGridTextColumn Header="المدفوع" Binding="{Binding PaidAmount, Converter={StaticResource FlexibleNumberConverter}}" Width="90" MinWidth="75" ElementStyle="{DynamicResource DataGridTextNumeric}"/>
                            <DataGridTextColumn Header="المتبقي" Binding="{Binding RemainingAmount, Converter={StaticResource FlexibleNumberConverter}}" Width="90" MinWidth="75" ElementStyle="{DynamicResource DataGridTextNumeric}"/>
                            <DataGridTextColumn Header="تاريخ الاستلام" Binding="{Binding IntakeDate}" Width="100" MinWidth="85" ElementStyle="{DynamicResource DataGridTextCenter}"/>
                            <DataGridTextColumn Header="التسليم المتوقع" Binding="{Binding ExpectedDelivery}" Width="100" MinWidth="85" ElementStyle="{DynamicResource DataGridTextCenter}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Style="{DynamicResource DataGridEmptyState}" Text="لا توجد طلبات صيانة للعرض">
                        <TextBlock.Visibility>
                            <MultiBinding Converter="{StaticResource SearchEmptyStateConverter}" ConverterParameter="NoData">
                                <Binding Path="HasItems" ElementName="MaintenanceGrid"/>
                                <Binding Path="SearchText"/>
                            </MultiBinding>
                        </TextBlock.Visibility>
                    </TextBlock>
                    <TextBlock Style="{DynamicResource DataGridEmptyState}" Text="لا توجد نتائج مطابقة للبحث">
                        <TextBlock.Visibility>
                            <MultiBinding Converter="{StaticResource SearchEmptyStateConverter}" ConverterParameter="NoResults">
                                <Binding Path="HasItems" ElementName="MaintenanceGrid"/>
                                <Binding Path="SearchText"/>
                            </MultiBinding>
                        </TextBlock.Visibility>
                    </TextBlock>
                    <Border Style="{DynamicResource DataGridLoadingState}"
                            Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Style="{DynamicResource DataGridLoadingText}" Text="⏳ جاري التحميل..."/>
                    </Border>
                </Grid>

                <!-- Status bar -->
                <Grid Grid.Row="3" Margin="24,8,24,16">
                    <TextBlock Foreground="{DynamicResource TextMutedBrush}" FontSize="12"
                               VerticalAlignment="Center">
                        <Run Text="عدد الطلبات: "/>
                        <Run Text="{Binding Orders.Count, Mode=OneWay}"/>
                        <Run Text="  |  انقر نقراً مزدوجاً لفتح الطلب"/>
                    </TextBlock>
                </Grid>

            </Grid>
        </Border>
    </Grid>
</Page>
