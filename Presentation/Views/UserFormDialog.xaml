<Window x:Class="AlJohary.ServiceHub.Presentation.Views.UserFormDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:AlJohary.ServiceHub.Shared.Helpers"
        xmlns:converters="clr-namespace:AlJohary.ServiceHub.Presentation.Converters"
        Title="مستخدم جديد" 
        MaxHeight="700" Width="480"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FlowDirection="RightToLeft">
        
    <Window.Resources>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
    </Window.Resources>

    <Border x:Name="DialogBorder" Style="{DynamicResource StandardWindowContentBorder}">
        <Border.OpacityMask>
            <VisualBrush>
                <VisualBrush.Visual>
                    <Border Background="Black" 
                            Width="{Binding ActualWidth, ElementName=DialogBorder}"
                            Height="{Binding ActualHeight, ElementName=DialogBorder}"
                            CornerRadius="12"/>
                </VisualBrush.Visual>
            </VisualBrush>
        </Border.OpacityMask>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="{Binding Title, StringFormat='👤 {0}'}" 
                           FontFamily="{DynamicResource MainFontSemibold}"
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="{DynamicResource PrimaryBrush}"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"/>

                <Button Style="{DynamicResource CloseButton}" 
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Command="{Binding CancelCommand}"/>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="450">
                <StackPanel Margin="0,0,12,0">
                    <Label Content="اسم المستخدم" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                    <TextBox x:Name="UsernameTextBox" 
                             Style="{DynamicResource MainTextBox}"
                             Margin="0,0,0,16"
                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsEditMode, Converter={StaticResource InverseBooleanConverter}, FallbackValue=True}"/>
    
                    <Label Content="الاسم الكامل" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                    <TextBox x:Name="FullNameTextBox" 
                             Style="{DynamicResource MainTextBox}"
                             Margin="0,0,0,16"
                             Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"/>
    
                    <Label Content="كلمة المرور" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
    
                        <PasswordBox x:Name="PasswordBox" 
                                     Grid.Column="0"
                                     Style="{DynamicResource MainPasswordBox}"/>
    
                        <TextBox x:Name="PasswordTextBox" 
                                 Grid.Column="0"
                                 Style="{DynamicResource MainTextBox}"
                                 Visibility="Collapsed"
                                 Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"/>
    
                        <Button x:Name="TogglePasswordButton"
                                Grid.Column="1"
                                Content="👁️"
                                Width="30" Height="30"
                                Margin="4,0,0,0"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="TogglePassword_Click"
                                ToolTip="عرض/إخفاء كلمة المرور"/>
                    </Grid>
    
                    <Label Content="الصلاحية" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                    <ComboBox x:Name="RoleComboBox" 
                              Style="{DynamicResource MainComboBox}"
                              Margin="0,0,0,16"
                              SelectedValue="{Binding Role, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Tag">
                        <ComboBoxItem Tag="admin">مدير</ComboBoxItem>
                        <ComboBoxItem Tag="employee">موظف</ComboBoxItem>
                    </ComboBox>
    
                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
    
                        <StackPanel Grid.Column="0">
                            <Label Content="أقصى نسبة خصم (%)" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                            <TextBox Style="{DynamicResource MainTextBox}"
                                     Text="{Binding MaxDiscountPercent, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
    
                        <StackPanel Grid.Column="2">
                            <Label Content="أقصى نسبة زيادة (%)" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                            <TextBox Style="{DynamicResource MainTextBox}"
                                     Text="{Binding MaxMarkupPercent, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,24,0,0">
                <Button x:Name="CreateButton" 
                        Content="{Binding ButtonText}" 
                        Style="{DynamicResource PrimaryButton}" 
                        Width="140" Margin="8,0" 
                        IsDefault="True"
                        Command="{Binding SaveCommand}"/>
                <Button Content="إلغاء" 
                        Style="{DynamicResource DarkButton}" 
                        Width="120" Margin="8,0" 
                        IsCancel="True"
                        Command="{Binding CancelCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
