<Window x:Class="AlJohary.ServiceHub.Presentation.Views.EmployeeSalaryTransactionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="عملية راتب"
        SizeToContent="WidthAndHeight"
        MinWidth="450"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        FlowDirection="RightToLeft">

    <Border Style="{DynamicResource StandardWindowContentBorder}">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="{Binding DialogTitle}"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryBrush}"
                           VerticalAlignment="Center"
                           FontFamily="{DynamicResource MainFontSemibold}"/>

                <Button Style="{DynamicResource CloseButton}"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Click="CancelButton_Click"/>
            </Grid>

            <StackPanel Grid.Row="1">
                <Border Background="{DynamicResource BgCardBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,16" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="الموظف" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding EmployeeName}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="{DynamicResource MainFontSemibold}"/>
                    </StackPanel>
                </Border>

                <Label Content="{Binding AmountLabel}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                <TextBox x:Name="AmountTextBox"
                         Style="{DynamicResource MainTextBox}"
                         PreviewTextInput="DecimalTextBox_PreviewTextInput"
                         Margin="0,0,0,2"/>
                <TextBlock Text="{Binding AmountHelperText}"
                           FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="2,0,0,16"/>

                <Label Content="تاريخ العملية" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                <DatePicker x:Name="TransactionDatePicker" Margin="0,0,0,16"/>

                <StackPanel x:Name="PaymentMethodPanel" Margin="0,0,0,16">
                    <Label Content="طريقة الدفع" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                    <ComboBox x:Name="PaymentMethodComboBox"
                              Style="{DynamicResource MainComboBox}"
                              ItemsSource="{Binding PaymentMethodOptions}"
                              SelectedIndex="0"/>
                </StackPanel>

                <Label Content="ملاحظات" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                <TextBox x:Name="NotesTextBox"
                         Style="{DynamicResource MainTextBox}"
                         Height="70"
                         TextWrapping="Wrap"
                         VerticalContentAlignment="Top"
                         Padding="12,10"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,24,0,0">
                <Button Content="حفظ"
                        Style="{DynamicResource PrimaryButton}"
                        MinWidth="120"
                        Margin="8,0"
                        IsDefault="True"
                        Click="SaveButton_Click"/>
                <Button Content="إلغاء"
                        Style="{DynamicResource DarkButton}"
                        MinWidth="120"
                        Margin="8,0"
                        IsCancel="True"
                        Click="CancelButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
