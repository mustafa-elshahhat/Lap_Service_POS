<Page x:Class="AlJohary.ServiceHub.Presentation.Views.ExpensesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="المصروفات"
      Background="{DynamicResource BgMainBrush}"
      FlowDirection="RightToLeft"
      UseLayoutRounding="True"
      SnapsToDevicePixels="True">
    
    <Grid Margin="{DynamicResource PageContentMargin}">
        <Border Background="{DynamicResource BgCardBrush}" 
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                
                <Grid Grid.Row="0" Margin="24" FlowDirection="LeftToRight">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <WrapPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" FlowDirection="RightToLeft">
                        <Button Content="➕ مصروف جديد"
                                Style="{DynamicResource PrimaryButton}"
                                MinWidth="140"
                                Margin="4,0"
                                Command="{Binding AddExpenseCommand}"/>
                        <Button Content="🔄 عرض الكل"
                                Style="{DynamicResource DarkButton}"
                                MinWidth="140"
                                Margin="4,0"
                                Command="{Binding LoadAllCommand}"/>
                    </WrapPanel>

                    <TextBlock Grid.Column="2" 
                               Text="💸 إدارة المصروفات" 
                               FontFamily="{DynamicResource MainFontSemibold}"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Right"
                               FlowDirection="RightToLeft"
                               VerticalAlignment="Center"/>
                </Grid>
                
                
                <Grid Grid.Row="1" Margin="24,0,24,16">
                    <TextBox x:Name="SearchTextBox"
                             Style="{DynamicResource SearchTextBoxStyle}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                    
                    <StackPanel Orientation="Horizontal" IsHitTestVisible="False" Margin="12,0" VerticalAlignment="Center">
                        <TextBlock Text="🔍" FontSize="16" Margin="0,0,8,0" Foreground="{DynamicResource TextMutedBrush}"/>
                        <TextBlock Text="ابحث في المصروفات..." Foreground="{DynamicResource TextMutedBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Grid>
                
                
                <Grid Grid.Row="2">
                <DataGrid x:Name="ExpensesGrid"
                          Style="{DynamicResource MainDataGrid}"
                          Margin="24,0,24,24"
                          ItemsSource="{Binding Expenses}"
                          SelectedItem="{Binding SelectedExpense}"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="م" Binding="{Binding [id]}" Width="60" MinWidth="50" ElementStyle="{DynamicResource DataGridTextCenter}"/>
                        <DataGridTextColumn Header="الوصف" Binding="{Binding [description]}" Width="2*"/>
                        <DataGridTextColumn Header="الفئة" Binding="{Binding [category]}" Width="120" MinWidth="100" ElementStyle="{DynamicResource DataGridTextCenter}"/>
                        <DataGridTextColumn Header="المبلغ" Binding="{Binding [amount], Converter={StaticResource FlexibleNumberConverter}}" Width="100" MinWidth="90">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridTextCenter}">
                                    <Setter Property="Foreground" Value="{DynamicResource WarningDarkBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="طريقة الدفع" Binding="{Binding [payment_method]}" Width="100" MinWidth="90" ElementStyle="{DynamicResource DataGridTextCenter}"/>
                        <DataGridTextColumn Header="التاريخ" Binding="{Binding [expense_date]}" Width="120" MinWidth="100" ElementStyle="{DynamicResource DataGridTextCenter}"/>
                        <DataGridTextColumn Header="المستخدم" Binding="{Binding [user_name]}" Width="120" MinWidth="100" ElementStyle="{DynamicResource DataGridTextCenter}"/>
                    </DataGrid.Columns>
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="❌ حذف المصروف" Command="{Binding DeleteExpenseCommand}"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>
                <TextBlock Style="{DynamicResource DataGridEmptyState}"
                           Text="لا توجد مصروفات للعرض"
                           Visibility="{Binding HasItems, ElementName=ExpensesGrid, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
