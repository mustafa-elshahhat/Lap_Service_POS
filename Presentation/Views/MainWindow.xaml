<Window x:Class="AlJohary.ServiceHub.Presentation.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="الجوهري"
        Height="768" Width="1366"
        MinHeight="700" MinWidth="1024"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        FlowDirection="RightToLeft"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        Icon="pack://application:,,,/Presentation/Resources/Images/logo.png">
        
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Border x:Name="MainWindowBorder" ClipToBounds="True">
        <Border.OpacityMask>
            <VisualBrush>
                <VisualBrush.Visual>
                    <Border Background="Black" 
                            Width="{Binding ActualWidth, ElementName=MainWindowBorder}"
                            Height="{Binding ActualHeight, ElementName=MainWindowBorder}"
                            CornerRadius="{Binding CornerRadius, ElementName=MainWindowBorder}"/>
                </VisualBrush.Visual>
            </VisualBrush>
        </Border.OpacityMask>
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource BgMainBrush}"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="Margin" Value="0"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                        <Setter Property="CornerRadius" Value="0"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="64"/> 
                <RowDefinition Height="*"/>  
            </Grid.RowDefinitions>

            
            
            
            <Border Grid.Row="0" 
                    Background="{DynamicResource BgCardBrush}" 
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>  
                        <ColumnDefinition Width="Auto"/>  
                        <ColumnDefinition Width="*"/>     
                        <ColumnDefinition Width="Auto"/>  
                        <ColumnDefinition Width="Auto"/>  
                        <ColumnDefinition Width="Auto"/>  
                    </Grid.ColumnDefinitions>
                    
                    
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        
                        <Button x:Name="CloseBtn" Click="CloseButton_Click" Cursor="Hand" ToolTip="إغلاق">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Width="36" Height="36" CornerRadius="8" Background="Transparent">
                                        <TextBlock Text="✕" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource DangerLightBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        
                        <Button x:Name="MaximizeBtn" Click="MaximizeButton_Click" Cursor="Hand" ToolTip="تكبير">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Width="36" Height="36" CornerRadius="8" Background="Transparent">
                                        <TextBlock x:Name="icon" Text="☐" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource LightBrush}"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                                            <Setter TargetName="icon" Property="Text" Value="❐"/>
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        
                        <Button x:Name="MinimizeBtn" Click="MinimizeButton_Click" Cursor="Hand" ToolTip="تصغير">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Width="36" Height="36" CornerRadius="8" Background="Transparent">
                                        <TextBlock Text="─" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource LightBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                    
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding PageIcon}" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding PageTitle}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text=""
                                       FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </StackPanel>
                    
                    
                    <Border Grid.Column="3" Background="{DynamicResource LightBrush}" CornerRadius="8" Padding="12,6" Margin="0,0,16,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📅" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding CurrentDate}"
                                       FontSize="12"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    
                    <Border Grid.Column="4" Background="{DynamicResource LightBrush}" CornerRadius="8" Padding="10,6" Margin="0,0,8,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="32" Height="32" 
                                    CornerRadius="16" 
                                    Background="{DynamicResource PrimaryLightBrush}"
                                    Margin="0,0,10,0">
                                    
                                <TextBlock Text="👤" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding UserName}"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding UserRole}"
                                           FontSize="10"
                                           Foreground="{DynamicResource TextMutedBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    
                    <Button Grid.Column="5"
                            Command="{Binding LogoutCommand}"
                            Cursor="Hand"
                            VerticalAlignment="Center">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" 
                                        Background="#FFF5F5F7" 
                                        CornerRadius="10" 
                                        Padding="14,8"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform>
                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                    </Border.RenderTransform>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="logoutText" 
                                                   Text="تسجيل الخروج" 
                                                   FontSize="12" 
                                                   FontWeight="SemiBold" 
                                                   Foreground="#FF64748B"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="logoutIcon" 
                                                   Text="🚪" 
                                                   FontSize="14" 
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.2"/>
                                                    <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.2"/>
                                                    <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.ExitActions>
                                        <Setter TargetName="border" Property="Background" Value="{DynamicResource DangerBrush}"/>
                                        <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource DangerDarkBrush}"/>
                                        <Setter TargetName="logoutText" Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    
                    <ColumnDefinition Width="260"/>
                    
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                
                <Border Grid.Column="0" 
                        Background="{DynamicResource BgSidebarBrush}"
                        BorderBrush="{DynamicResource BorderDarkBrush}"
                        BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> 
                            <RowDefinition Height="*"/>    
                            <RowDefinition Height="Auto"/> 
                        </Grid.RowDefinitions>
                        
                        
                        <StackPanel Grid.Row="0" Margin="0,50,0,30" HorizontalAlignment="Center">
                            
                            <Border Background="White" CornerRadius="10" Padding="8"
                                    FlowDirection="LeftToRight">
                                <Image Width="190" Height="90"
                                       Source="/Presentation/Resources/Images/logo.png"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                        </StackPanel>
                        
                        
                        <ScrollViewer Grid.Row="1" 
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="0,0,0,20"
                                      Margin="0,0,0,20"> 
                            <StackPanel>
                                <StackPanel.Resources>
                                    <Style x:Key="SidebarButtonStyle" TargetType="Button" BasedOn="{StaticResource NavButton}">
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Value="True">
                                                        <Condition.Binding>
                                                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                                                <Binding Path="CommandParameter" RelativeSource="{RelativeSource Self}"/>
                                                                <Binding Path="DataContext.ActiveNavTag" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                            </MultiBinding>
                                                        </Condition.Binding>
                                                    </Condition>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Tag" Value="Active"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Resources>

                                
                                <TextBlock Text="العمليات التشغيلية" 
                                            FontSize="11"
                                            FontWeight="Bold"
                                            Foreground="{DynamicResource TextMutedBrush}"
                                            Margin="24,10,24,10"
                                            HorizontalAlignment="Left"
                                            Opacity="0.6"/>
                                
                                <Button Content="🛒  نقطة البيع" 
                                        Style="{StaticResource SidebarButtonStyle}"
                                        Command="{Binding NavigateCommand}"
                                        CommandParameter="POS"/>
                                
                                <Button Content="👥  العملاء" 
                                        Style="{StaticResource SidebarButtonStyle}"
                                        Command="{Binding NavigateCommand}"
                                        CommandParameter="Customers"/>
                                
                                <Button Content="💸  المصروفات" 
                                        Style="{StaticResource SidebarButtonStyle}"
                                        Command="{Binding NavigateCommand}"
                                        CommandParameter="Expenses"/>
                                
                                <Button Content="🧾  الفواتير"
                                        Style="{StaticResource SidebarButtonStyle}"
                                        Command="{Binding NavigateCommand}"
                                        CommandParameter="Invoices"/>

                                <Button Content="🔁  المرتجعات"
                                        Style="{StaticResource SidebarButtonStyle}"
                                        Command="{Binding NavigateCommand}"
                                        CommandParameter="Returns"/>

                                <Button Content="🔧  الصيانة"
                                        Style="{StaticResource SidebarButtonStyle}"
                                        Command="{Binding NavigateCommand}"
                                        CommandParameter="Maintenance"/>
                                
                                
                                <StackPanel Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="إدارة المخزون" 
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               Margin="24,24,24,10"
                                               HorizontalAlignment="Left"
                                               Opacity="0.6"/>
                                    
                                    <Button Content="📦  المخزون" 
                                            Style="{StaticResource SidebarButtonStyle}"
                                            Command="{Binding NavigateCommand}"
                                            CommandParameter="Inventory"/>
                                    
                                    <Button Content="🏢  الموردين" 
                                            Style="{StaticResource SidebarButtonStyle}"
                                            Command="{Binding NavigateCommand}"
                                            CommandParameter="Suppliers"/>
                                    
                                    
                                    <TextBlock Text="النظام والإعدادات" 
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               Margin="24,24,24,10"
                                               HorizontalAlignment="Left"
                                               Opacity="0.6"/>
                                    
                                    <Button Content="📊  التقارير" 
                                            Style="{StaticResource SidebarButtonStyle}"
                                            Command="{Binding NavigateCommand}"
                                            CommandParameter="Reports"/>
                                    
                                    <Button Content="👤  المستخدمين" 
                                            Style="{StaticResource SidebarButtonStyle}"
                                            Command="{Binding NavigateCommand}"
                                            CommandParameter="Users"/>
                                    
                                    <Button Content="⚙️  الإعدادات" 
                                            Style="{StaticResource SidebarButtonStyle}"
                                            Command="{Binding NavigateCommand}"
                                            CommandParameter="Settings"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                        
                        
                        <TextBlock Grid.Row="2" 
                                   Text="الإصدار 1.0.0" 
                                   FontSize="10" 
                                   Foreground="{DynamicResource TextSecondaryBrush}" 
                                   HorizontalAlignment="Center" 
                                   Margin="0,0,0,16"/>
                    </Grid>
                </Border>
                
                <Grid Grid.Column="1" Background="{DynamicResource BgMainBrush}">
                     <Frame Content="{Binding CurrentPage}" 
                            NavigationUIVisibility="Hidden"
                            BorderThickness="0"
                            Background="{x:Null}"
                            Margin="0"
                            Focusable="False"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
