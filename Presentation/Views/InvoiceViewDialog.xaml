<Window x:Class="AlJohary.ServiceHub.Presentation.Views.InvoiceViewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:AlJohary.ServiceHub.Presentation.Helpers"
        Title="عرض الفاتورة" 
        Width="982" Height="732"
        MinWidth="832" MinHeight="632"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FlowDirection="RightToLeft"
        helpers:DialogChrome.DimOwner="True">

    <Window.Resources>
        <Style x:Key="CenterText" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Border x:Name="DialogBorder" Style="{DynamicResource StandardWindowContentBorder}">

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> 
                <RowDefinition Height="Auto"/> 
                <RowDefinition Height="Auto"/> 
                <RowDefinition Height="*"/>    
                <RowDefinition Height="Auto"/> 
                <RowDefinition Height="Auto"/> 
            </Grid.RowDefinitions>

            
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="تفاصيل الفاتورة" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <Border Margin="16,0,0,0" CornerRadius="6" Padding="10,4" Background="{Binding StatusBackground}" VerticalAlignment="Center">
                            <TextBlock Text="{Binding StatusText}" FontSize="12" FontWeight="SemiBold" Foreground="{Binding StatusForeground}"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding InvoiceMeta}" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" Margin="0,6,0,0"/>
                </StackPanel>
                
                <Button Grid.Column="1" Style="{DynamicResource CloseButton}" 
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Command="{Binding CloseCommand}"/>
            </Grid>

            
            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/> 
                </Grid.ColumnDefinitions>

                
                <Border Grid.Column="0" Background="{DynamicResource BgMainBrush}" CornerRadius="12" Padding="16" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" MinHeight="100">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="الإجمالي الأصلي" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalText}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                
                
                <Border Grid.Column="2" Background="{DynamicResource DangerLightBrush}" CornerRadius="12" Padding="16" BorderBrush="{DynamicResource DangerBrush}" BorderThickness="1" MinHeight="100">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="المرتجعات" FontSize="13" Foreground="{DynamicResource DangerDarkBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding ReturnsText}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource DangerDarkBrush}" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                
                <Border Grid.Column="4" Background="{DynamicResource SecondaryLightBrush}" CornerRadius="12" Padding="16" BorderBrush="{DynamicResource SecondaryBrush}" BorderThickness="1" MinHeight="100">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="الصافي المدفوع" FontSize="13" Foreground="{DynamicResource SecondaryDarkBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding PaidText}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource SecondaryBrush}" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                
                <Border Grid.Column="6" Background="{DynamicResource PrimaryLighterBrush}" CornerRadius="12" Padding="16" BorderBrush="{DynamicResource PrimaryLightBrush}" BorderThickness="1" MinHeight="100">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="المتبقي" FontSize="13" Foreground="{DynamicResource PrimaryDarkBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding RemainingText}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
            
            
            <Grid Grid.Row="2" Margin="0,0,0,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="💳 طرق الدفع" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                <ItemsControl Grid.Row="1" ItemsSource="{Binding PaymentMethods}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource WhiteBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,0,12,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Key}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding Value, Converter={StaticResource FlexibleNumberConverter}, StringFormat=': {0}'}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" 
                                               Visibility="{Binding ShowAmount, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </StackPanel>
                            </Border> 
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
 
            
             <Border Grid.Row="4" x:Name="RefundPreviewPanel"
                     Background="{DynamicResource WarningLightBrush}" CornerRadius="8" Padding="12" BorderBrush="{DynamicResource WarningBrush}" BorderThickness="1" 
                     Visibility="{Binding IsRefundPreviewVisible, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Hidden}" 
                     Margin="0,10,0,0" HorizontalAlignment="Center" Width="350">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="سيتم استرجاع:" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource WarningDarkBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding RefundTotalText}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource DangerBrush}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            
            <DataGrid Grid.Row="3" Margin="0,0,0,10" 
                      ItemsSource="{Binding ReturnLines}"
                      AutoGenerateColumns="False" IsReadOnly="False" 
                      CanUserAddRows="False" Style="{DynamicResource DialogDataGrid}"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      FlowDirection="LeftToRight">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="50" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    
                    <DataGridTemplateColumn Header="المنتج" Width="*" IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding ProductName}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <Border Background="{DynamicResource DangerLightBrush}" CornerRadius="4" Margin="8,0,0,0" Padding="6,2" VerticalAlignment="Center"
                                            Visibility="{Binding HasReturns, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="{Binding AlreadyReturned, StringFormat='تم استرجاع: {0}'}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource DangerBrush}"/>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="الكمية" Binding="{Binding Quantity}" Width="100" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    
                    <DataGridTextColumn Header="سعر الوحدة" Binding="{Binding UnitPrice, Converter={StaticResource FlexibleNumberConverter}}" Width="120" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    
                    <DataGridTextColumn Header="الإجمالي" Binding="{Binding TotalPrice, Converter={StaticResource FlexibleNumberConverter}}" Width="120" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    
                    <DataGridTemplateColumn Header="المرتجع" Width="160">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Button Content="-" Style="{DynamicResource CircleButton}" Width="28" Height="28" FontSize="14" FontWeight="Bold" 
                                            Command="{Binding DataContext.DecReturnCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                            CommandParameter="{Binding}"
                                            Background="{DynamicResource LightBrush}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    
                                    <TextBox Text="{Binding ReturnQuantity, UpdateSourceTrigger=PropertyChanged}" 
                                             Width="45" Height="28"
                                             HorizontalContentAlignment="Center" 
                                             VerticalContentAlignment="Center"
                                             FontSize="14" FontWeight="SemiBold"
                                             Background="Transparent" BorderThickness="0"
                                             IsReadOnly="True"
                                             Padding="0"/>
                                    
                                    <Button Content="+" Style="{DynamicResource CircleButton}" Width="28" Height="28" FontSize="14" FontWeight="Bold" 
                                            Command="{Binding DataContext.IncReturnCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                            CommandParameter="{Binding}"
                                            Background="{DynamicResource DangerLightBrush}" Foreground="{DynamicResource DangerBrush}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            
            <Grid Grid.Row="5" Margin="0,24,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="إغلاق" Style="{DynamicResource DarkButton}" MinWidth="100" IsCancel="True" Command="{Binding CloseCommand}"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="🖨️ طباعة الفاتورة" Style="{DynamicResource PrimaryButton}" MinWidth="150" Margin="0,0,16,0" Command="{Binding PrintCommand}"/>
                    <Button Content="{Binding RefundButtonContent}" Style="{DynamicResource DangerButton}" MinWidth="150"
                            Command="{Binding ProcessRefundCommand}" IsEnabled="{Binding IsRefundButtonEnabled}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
