<Page x:Class="AlJohary.ServiceHub.Presentation.Views.POSPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="نقطة البيع"
      Background="{DynamicResource BgMainBrush}"
      FlowDirection="RightToLeft"
      UseLayoutRounding="True"
      SnapsToDevicePixels="True">

    <Grid Margin="{DynamicResource PageContentMargin}" x:Name="PosRootGrid" SizeChanged="PosRootGrid_SizeChanged">
        <Grid.ColumnDefinitions>

            <ColumnDefinition Width="*" MinWidth="480"/>

            <ColumnDefinition x:Name="CartColumn" Width="320" MinWidth="280"/>
        </Grid.ColumnDefinitions>

        
        
        
        <Grid Grid.Column="0" Margin="0,0,16,0" x:Name="ProductsRoot">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> 
                <RowDefinition Height="*"/>    
                <RowDefinition Height="Auto"/> 
            </Grid.RowDefinitions>

            
            <Border Grid.Row="0" 
                    Background="{DynamicResource BgCardBrush}" 
                    CornerRadius="12" 
                    Padding="16" 
                    Margin="0,0,0,16"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <TextBox x:Name="SearchTextBox"
                             Style="{DynamicResource SearchTextBoxStyle}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding SearchEnterCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    
                    <StackPanel Orientation="Horizontal" IsHitTestVisible="False" Margin="12,0" VerticalAlignment="Center">
                         <TextBlock Text="🔍" FontSize="16" Margin="0,0,8,0" Foreground="{DynamicResource TextMutedBrush}"/>
                         <TextBlock Text="ابحث عن منتج بالاسم أو الكود..." 
                                    Foreground="{DynamicResource TextMutedBrush}">
                             <TextBlock.Style>
                                 <Style TargetType="TextBlock">
                                     <Setter Property="Visibility" Value="Collapsed"/>
                                     <Style.Triggers>
                                         <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                             <Setter Property="Visibility" Value="Visible"/>
                                         </DataTrigger>
                                     </Style.Triggers>
                                 </Style>
                             </TextBlock.Style>
                         </TextBlock>
                    </StackPanel>
                </Grid>

            </Border>

            
            <Border Grid.Row="1" 
                    x:Name="ProductsGridBorder"
                    Background="{DynamicResource BgCardBrush}" 
                    CornerRadius="12"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <Border.OpacityMask>
                    <VisualBrush>
                        <VisualBrush.Visual>
                            <Border Background="Black" 
                                    Width="{Binding ActualWidth, ElementName=ProductsGridBorder}"
                                    Height="{Binding ActualHeight, ElementName=ProductsGridBorder}"
                                    CornerRadius="12"/>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </Border.OpacityMask>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="نتائج البحث" 
                               FontFamily="{DynamicResource MainFontSemibold}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Left"
                               Margin="16,16,16,8"/>
                    
                    <DataGrid x:Name="ProductsGrid"
                               Grid.Row="1"
                               Style="{DynamicResource DialogDataGrid}"
                               Margin="16,8,16,16"
                               ItemsSource="{Binding SearchResults}"
                               SelectedItem="{Binding SelectedProduct}"
                               IsReadOnly="True"
                               ScrollViewer.VerticalScrollBarVisibility="Auto">

                        <DataGrid.InputBindings>
                            <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding AddToCartCommand}"/>
                        </DataGrid.InputBindings>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Id}" Width="60" MinWidth="50" ElementStyle="{DynamicResource DataGridTextCenter}"/>
                            <DataGridTextColumn Header="اسم المنتج" Binding="{Binding Name}" Width="*" MinWidth="140"/>
                            <DataGridTextColumn Header="السعر" Binding="{Binding SellingPrice, Converter={StaticResource FlexibleNumberConverter}}" Width="100" MinWidth="90" ElementStyle="{DynamicResource DataGridTextNumeric}"/>
                            <DataGridTextColumn Header="المخزون" Binding="{Binding Quantity}" Width="90" MinWidth="80" ElementStyle="{DynamicResource DataGridTextNumeric}"/>
                        </DataGrid.Columns>
                        
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="➕ إضافة للسلة" Command="{Binding AddToCartCommand}"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                    </DataGrid>
                    <TextBlock Grid.Row="1" Style="{DynamicResource DataGridEmptyState}"
                               Text="🔍 ابحث لإظهار المنتجات"
                               Visibility="{Binding HasItems, ElementName=ProductsGrid, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

                </Grid>
            </Border>
            

        </Grid>

        
        
        
        <Border Grid.Column="1" 
                x:Name="CartBorder"
                Background="{DynamicResource BgCardBrush}" 
                CornerRadius="12" 
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <Border.OpacityMask>
                <VisualBrush>
                    <VisualBrush.Visual>
                        <Border Background="Black" 
                                Width="{Binding ActualWidth, ElementName=CartBorder}"
                                Height="{Binding ActualHeight, ElementName=CartBorder}"
                                CornerRadius="12"/>
                    </VisualBrush.Visual>
                </VisualBrush>
            </Border.OpacityMask>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> 
                    <RowDefinition Height="*"/>    
                    <RowDefinition Height="Auto"/> 
                    <RowDefinition Height="Auto"/> 
                </Grid.RowDefinitions>

                
                <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16">
                    <DockPanel>
                         <Button DockPanel.Dock="Right" 
                             Content="🗑️ تفريغ" 
                             Style="{DynamicResource DangerButton}" 
                             Padding="12,0"
                             Command="{Binding ClearCartCommand}"/>
                         
                         <TextBlock Text="سلة المشتريات" 
                                    FontFamily="{DynamicResource MainFontSemibold}"
                                    FontSize="16" 
                                    FontWeight="Bold" 
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                
                <DataGrid x:Name="CartGrid"
                          Grid.Row="1"
                          Style="{DynamicResource DialogDataGrid}"
                          Margin="12,8"
                          ItemsSource="{Binding Cart.Items}"
                          SelectedItem="{Binding Cart.SelectedItem}"
                          IsReadOnly="True"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="المنتج" Binding="{Binding ProductName}" Width="*"/>
                        <DataGridTextColumn Header="العدد" Binding="{Binding Quantity}" Width="50" ElementStyle="{DynamicResource DataGridTextNumeric}"/>
                        <DataGridTextColumn Header="إجمالي" Binding="{Binding Total, Converter={StaticResource FlexibleNumberConverter}}" Width="90" ElementStyle="{DynamicResource DataGridTextNumeric}" FontWeight="Bold"/>
                    </DataGrid.Columns>
                    
                    <DataGrid.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding EditQuantityCommand}"/>
                    </DataGrid.InputBindings>

                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="✏️ تعديل الكمية" Command="{Binding EditQuantityCommand}"/>
                            <MenuItem Header="💰 تعديل السعر" Command="{Binding EditPriceCommand}"/>
                            <Separator/>
                            <MenuItem Header="🗑️ حذف من السلة" Command="{Binding RemoveFromCartCommand}"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>
                <TextBlock Grid.Row="1" Style="{DynamicResource DataGridEmptyState}"
                           Text="🛒 السلة فارغة"
                           Visibility="{Binding Cart.IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                
                <Border Grid.Row="2" Margin="12,8" CornerRadius="12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="20">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="{DynamicResource BgCardColor}" Offset="0"/>
                            <GradientStop Color="{DynamicResource BgMainColor}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                            <TextBlock Text="🧾" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="الإجمالي النهائي" 
                                       FontFamily="{DynamicResource MainFontSemibold}"
                                       Foreground="{DynamicResource TextSecondaryBrush}" 
                                       FontSize="16" 
                                       FontWeight="Bold"/>
                        </StackPanel>

                        <TextBlock Grid.Row="1" 
                                   x:Name="TotalLabel" 
                                   Text="{Binding Cart.Total, Converter={StaticResource FlexibleCurrencyConverter}}" 
                                   NumberSubstitution.Substitution="European"
                                   FontFamily="{DynamicResource MainFont}"
                                   Foreground="{DynamicResource SecondaryDarkBrush}" 
                                   FontSize="42" 
                                   FontWeight="ExtraBold" 
                                   HorizontalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="{DynamicResource SecondaryColor}" Direction="270" ShadowDepth="0" BlurRadius="10" Opacity="0.15"/>
                            </TextBlock.Effect>
                        </TextBlock>

                    </Grid>
                </Border>

                
                <StackPanel Grid.Row="3" Background="{DynamicResource BgCardBrush}" Margin="0">
                    
                    
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="8" Background="{DynamicResource LightBrush}">
                        <UniformGrid Columns="3" Rows="1">
                            <Button Content="تعديل الكمية" Style="{DynamicResource InfoButton}" Margin="4" Command="{Binding EditQuantityCommand}"/>
                            <Button Content="تعديل السعر" Style="{DynamicResource WarningButton}" Margin="4" Command="{Binding EditPriceCommand}"/>
                            <Button Content="حذف المحدد" Style="{DynamicResource DangerButton}" Margin="4" Command="{Binding RemoveFromCartCommand}"/>
                        </UniformGrid>
                    </Border>

                    
                    <Button Style="{DynamicResource SecondaryButton}" 
                            Height="65"
                            Margin="16"
                            Command="{Binding CheckoutCashCommand}">
                        <Button.Content>
                            <Grid>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,2">
                                        <TextBlock Text="💳" FontSize="20" Margin="0,0,8,0"/>
                                        <TextBlock Text="كاش" FontSize="18" FontWeight="Bold"/>
                                    </StackPanel>
                                    <TextBlock Text="دفع فوري" FontSize="11" Opacity="0.8" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Button.Content>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>

