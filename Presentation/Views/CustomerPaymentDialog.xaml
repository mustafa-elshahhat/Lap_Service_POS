<Window x:Class="CarPartsShopWPF.Presentation.Views.CustomerPaymentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="سداد مديونية العميل" 
        Width="950" MaxHeight="720"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FlowDirection="RightToLeft"
        KeyDown="Window_KeyDown">

    <Border Style="{DynamicResource StandardWindowContentBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> 
                <RowDefinition Height="*"/>    
                <RowDefinition Height="Auto"/> 
            </Grid.RowDefinitions>

            
            <Border Grid.Row="0" Background="{DynamicResource PrimaryBrush}" Padding="20,16" CornerRadius="16,16,0,0">
                <Grid>
                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                        <TextBlock Text="💳 سداد مديونية العميل" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Left"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Text="{Binding CustomerNameHeader}" FontSize="13" Foreground="{DynamicResource PrimaryLightBrush}"/>
                            <TextBlock Text="  |  " Foreground="{DynamicResource PrimaryLightBrush}"/>
                            <TextBlock Text="إجمالي الدين: " FontSize="13" Foreground="{DynamicResource PrimaryLightBrush}"/>
                            <TextBlock Text="{Binding TotalDebtText}" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource WarningLightBrush}"/>
                        </StackPanel>
                    </StackPanel>
                     <Button Style="{DynamicResource CloseButton}" 
                             HorizontalAlignment="Right" VerticalAlignment="Top"
                             Foreground="White"
                             Command="{Binding CloseCommand}">
                        <Button.Resources>
                            <Style TargetType="Button" BasedOn="{StaticResource CloseButton}">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#30FFFFFF"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="500">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
    
                    
                    <Border Grid.Column="0" Background="{DynamicResource BgCardBrush}" CornerRadius="8" Padding="12" 
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" MinHeight="350">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="📋 اختر الفاتورة" FontWeight="Bold" 
                                       FontFamily="{DynamicResource MainFontSemibold}"
                                       FontSize="15" Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,12"/>
                            
                            <DataGrid x:Name="InvoicesGrid" 
                                      Style="{DynamicResource MainDataGrid}" 
                                      IsReadOnly="True"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto"
                                      FlowDirection="LeftToRight"
                                      SelectionMode="Extended"
                                      ItemsSource="{Binding Invoices}"
                                      SelectionChanged="InvoicesGrid_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#" Binding="{Binding Id}" Width="50" ElementStyle="{DynamicResource DataGridTextCenter}"/>
                                    <DataGridTextColumn Header="الفاتورة" Binding="{Binding InvoiceNumber}" Width="Auto">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="Padding" Value="5,0"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
    
                                    <DataGridTextColumn Header="التاريخ" Binding="{Binding SaleDate, StringFormat=d}" Width="Auto">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridTextCenter}"/>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
    
                                    <DataGridTextColumn Header="المتبقي" Binding="{Binding RemainingAmount, StringFormat=N2}" Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Foreground" Value="{DynamicResource WarningDarkBrush}"/>
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="Padding" Value="5,0"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
    
                    
                    <Border Grid.Column="2" Background="{DynamicResource BgCardBrush}" CornerRadius="8" Padding="20" 
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="💵 بيانات السداد" FontWeight="Bold" 
                                       FontFamily="{DynamicResource MainFontSemibold}"
                                       FontSize="16" Foreground="{DynamicResource SecondaryBrush}" Margin="0,0,0,20"/>
    
                            
                            <Border x:Name="InvoiceInfoPanel" Background="{DynamicResource SecondaryLightBrush}" CornerRadius="6" 
                                    Padding="16" Margin="0,0,0,20" 
                                    Visibility="{Binding IsInvoiceInfoVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedInvoiceText}" FontWeight="Bold" FontFamily="{DynamicResource MainFontSemibold}" FontSize="14" Foreground="{DynamicResource SecondaryDarkBrush}"/>
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="الإجمالي:" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding InvTotalText}" FontWeight="SemiBold" FontSize="14"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="المتبقي:" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding InvRemainingText}" FontWeight="Bold" Foreground="{DynamicResource WarningDarkBrush}" FontSize="14"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
    
                            
                            <Label Content="طريقة الدفع"/>
                            <ComboBox x:Name="PaymentMethodCombo" 
                                      ItemsSource="{Binding PaymentMethods}"
                                      SelectedItem="{Binding SelectedPaymentMethod}"
                                      Margin="0,0,0,20"/>
    
                            
                            <Label Content="مبلغ السداد"/>
                            <TextBox x:Name="PaymentAmountTextBox" 
                                     FontWeight="Bold" 
                                     Text="{Binding PaymentAmountText, UpdateSourceTrigger=PropertyChanged}"/>
    
                            
                            <TextBlock Text="{Binding ValidationMessage}" FontSize="12" 
                                       Foreground="{DynamicResource DangerBrush}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>

            
            <Border Grid.Row="2" Background="{DynamicResource BgMainBrush}" Padding="20" CornerRadius="0,0,16,16" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="المبلغ: " Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"/>
                        <TextBlock Text="{Binding SummaryAmount}" FontWeight="Bold" FontSize="15"
                                   Foreground="{DynamicResource SecondaryBrush}" Margin="0,0,24,0"/>
                        <TextBlock Text="المتبقي بعد السداد: " Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"/>
                        <TextBlock Text="{Binding SummaryRemaining}" FontWeight="Bold" FontSize="15"
                                   Foreground="{DynamicResource InfoBrush}"/>
                    </StackPanel>

                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="إلغاء" Style="{DynamicResource DarkButton}" 
                                Width="100" Command="{Binding CloseCommand}" Margin="0,0,12,0" IsCancel="True"/>
                        <Button x:Name="PayButton" Content="✓ تأكيد السداد" 
                                Style="{DynamicResource PrimaryButton}" 
                                Width="140"
                                IsDefault="True"
                                Command="{Binding PayCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

