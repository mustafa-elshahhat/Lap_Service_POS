<Window x:Class="AlJohary.ServiceHub.Presentation.Views.SupplierTransactionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="حركات المورد"
        Width="750" Height="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FlowDirection="RightToLeft">

    <Border Style="{DynamicResource StandardWindowContentBorder}">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Button Style="{DynamicResource CloseButton}" 
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Click="CloseButton_Click"/>
                
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock Text="📜 سجل حركات المورد" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}"/>
                    <TextBlock x:Name="SupplierNameText" Text="-" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>

            
            <DataGrid x:Name="TransactionsGrid"
                      Grid.Row="1"
                      Style="{DynamicResource DialogDataGrid}"
                      IsReadOnly="True"
                      FlowDirection="LeftToRight">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding [id]}" Width="50">
                         <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="التاريخ" Binding="{Binding [transaction_date]}" Width="120">
                         <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="النوع" Binding="{Binding [transaction_type_ar]}" Width="100"/>
                    <DataGridTextColumn Header="المبلغ" Binding="{Binding [amount], StringFormat=N2}" Width="120">
                         <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="الرصيد بعد" Binding="{Binding [balance_after], StringFormat=N2}" Width="120">
                         <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="بواسطة" Binding="{Binding [created_by]}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            
            <StackPanel Grid.Row="2" Margin="0,24,0,0" HorizontalAlignment="Center" Orientation="Horizontal">
                <Button Style="{DynamicResource PrimaryButton}" Width="160" Height="48" Margin="0,0,16,0" Click="PrintReport_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Viewbox Width="18" Height="18">
                            <Path Data="M18,3H6V7H18M19,12A1,1 0 0,1 18,11A1,1 0 0,1 19,10A1,1 0 0,1 20,11A1,1 0 0,1 19,12M16,19H8V14H16M19,8H5A3,3 0 0,0 2,11V17H6V21H18V17H22V11A3,3 0 0,0 19,8Z" 
                                  Fill="White"/>
                        </Viewbox>
                        <TextBlock Text="طباعة كشف حساب" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Content="إغلاق" Style="{DynamicResource DarkButton}" Width="120" Height="48" IsCancel="True" Click="CloseButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

