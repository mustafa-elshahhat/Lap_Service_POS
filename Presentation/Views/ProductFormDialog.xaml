<Window x:Class="CarPartsShopWPF.Presentation.Views.ProductFormDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        SizeToContent="WidthAndHeight"
        MinWidth="500"
        MaxWidth="700"
        MaxHeight="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FlowDirection="RightToLeft"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    
    <Border x:Name="DialogBorder" Style="{DynamicResource StandardWindowContentBorder}">
        <Border.OpacityMask>
            <VisualBrush>
                <VisualBrush.Visual>
                    <Border Background="Black" 
                            Width="{Binding ActualWidth, ElementName=DialogBorder}"
                            Height="{Binding ActualHeight, ElementName=DialogBorder}"
                            CornerRadius="12"/>
                </VisualBrush.Visual>
            </VisualBrush>
        </Border.OpacityMask>
        <Grid Margin="24">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            
            <Grid Grid.Row="0" Margin="0,0,0,20">
                
                <Button Style="{DynamicResource CloseButton}" 
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Command="{Binding CancelCommand}"/>

                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock Text="{Binding TitleIcon}" 
                             FontSize="18" 
                             Margin="0,0,8,0" 
                             VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Title}"
                             FontFamily="{DynamicResource MainFontSemibold}"
                             FontSize="18"
                             FontWeight="SemiBold"
                             Foreground="{DynamicResource PrimaryBrush}"
                             VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
            
            
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" PanningMode="Both">
                <StackPanel Margin="0,0,16,0">
                    
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        
                        <StackPanel Grid.Column="2">
                            <Label Content="كود المنتج *"/>
                            <TextBox x:Name="CodeTextBox"
                                     IsReadOnly="True"
                                     Background="{DynamicResource BgMainBrush}"
                                     Foreground="{DynamicResource TextMutedBrush}"
                                     Text="{Binding Code}"/>
                        </StackPanel>
                        
                        
                        <StackPanel Grid.Column="0">
                            <Label Content="الباركود"/>
                            <Grid>
                                 <TextBox Padding="12,0,40,0"
                                          Text="{Binding Barcode, UpdateSourceTrigger=PropertyChanged}"/>
                                 <Button ToolTip="توليد باركود تلقائي"
                                        Width="30" Height="30"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Margin="0,0,5,0"
                                        Padding="0"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="{DynamicResource PrimaryBrush}"
                                        Cursor="Hand"
                                        Command="{Binding GenerateBarcodeCommand}">
                                     <Viewbox Width="20" Height="20">
                                         <Path Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"
                                               Fill="{DynamicResource PrimaryBrush}"
                                               Stretch="Uniform"/>
                                     </Viewbox>
                                 </Button>
                            </Grid>
                        </StackPanel>
                    </Grid>
                    
                    
                    <Label Content="اسم المنتج *"/>
                    <TextBox x:Name="NameTextBox"
                             Margin="0,0,0,16"
                             Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                    
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        
                        <StackPanel Grid.Column="2">
                            <Label Content="سعر الشراء *"/>
                            <TextBox Text="{Binding PurchasePrice, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        
                        
                        <StackPanel Grid.Column="0">
                            <Label Content="سعر البيع *"/>
                            <TextBox Text="{Binding SellingPrice, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>
                    
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        
                        <StackPanel Grid.Column="2">
                            <Label Content="الكمية"/>
                            <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        
                        
                        <StackPanel Grid.Column="0">
                            <Label Content="الحد الأدنى"/>
                            <TextBox Text="{Binding MinQuantity, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>
                    
                    
                    <Label Content="الفئة"/>
                    <TextBox Margin="0,0,0,16"
                             Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}"/>
                    
                    
                    <Label Content="المورد"/>
                    <TextBox Margin="0,0,0,16"
                             Text="{Binding SupplierName, UpdateSourceTrigger=PropertyChanged}"/>
                    
                    
                    <Label Content="الوصف"/>
                    <TextBox Height="80"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalContentAlignment="Top"
                             Padding="12,10"
                             VerticalScrollBarVisibility="Auto"
                             Margin="0,0,0,10"
                             Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"/>
                    
                </StackPanel>
            </ScrollViewer>
            
            
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,0">
                <Button Content="حفظ"
                        Style="{DynamicResource PrimaryButton}"
                        Width="120"
                        Margin="6,0"
                        IsDefault="True"
                        Command="{Binding SaveCommand}"/>
                <Button Content="إلغاء"
                        Style="{DynamicResource DarkButton}"
                        Width="100"
                        Margin="6,0"
                        IsCancel="True"
                        Command="{Binding CancelCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

