<Window x:Class="AlJohary.ServiceHub.Presentation.Views.ProductFormDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:AlJohary.ServiceHub.Presentation.Helpers"
        Title="{Binding Title}"
        helpers:DialogChrome.DimOwner="True"
        SizeToContent="WidthAndHeight"
        MinWidth="480"
        MaxWidth="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FlowDirection="RightToLeft"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Border x:Name="DialogBorder" Style="{DynamicResource StandardWindowContentBorder}">
        <Grid Margin="28,24,28,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Button Style="{DynamicResource CloseButton}"
                        HorizontalAlignment="Left" VerticalAlignment="Top"
                        Command="{Binding CancelCommand}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="{Binding TitleIcon}"
                               FontSize="18"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Title}"
                               FontFamily="{DynamicResource MainFontSemibold}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="1" Margin="0,0,0,8">

                <Label Content="اسم المنتج *"/>
                <TextBox x:Name="NameTextBox"
                         Margin="0,0,0,16"
                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <Label Content="سعر البيع *"/>
                        <TextBox Text="{Binding SellingPrice, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <Label Content="سعر الشراء *"/>
                        <TextBox Text="{Binding PurchasePrice, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <Label Content="الكمية"/>
                        <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <Label Content="الحد الأدنى"/>
                        <TextBox Text="{Binding MinQuantity, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>

                <Label Content="الفئة"/>
                <TextBox Margin="0,0,0,4"
                         Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}"/>

            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                <Button Content="حفظ"
                        Style="{DynamicResource PrimaryButton}"
                        MinWidth="120"
                        Margin="8,0"
                        IsDefault="True"
                        Command="{Binding SaveCommand}"/>
                <Button Content="إلغاء"
                        Style="{DynamicResource DarkButton}"
                        MinWidth="100"
                        Margin="8,0"
                        IsCancel="True"
                        Command="{Binding CancelCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

