<Window x:Class="CarPartsShopWPF.Presentation.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تسجيل الدخول - الجوهري"
        Height="550" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FlowDirection="RightToLeft"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Icon="pack://application:,,,/Presentation/Resources/Images/logo.png">

    <Border x:Name="LoginRoot" Background="{DynamicResource BgCardBrush}" CornerRadius="12" Margin="10">
        <Border.OpacityMask>
            <VisualBrush>
                <VisualBrush.Visual>
                    <Border Background="Black" 
                            Width="{Binding ActualWidth, ElementName=LoginRoot}"
                            Height="{Binding ActualHeight, ElementName=LoginRoot}"
                            CornerRadius="12"/>
                </VisualBrush.Visual>
            </VisualBrush>
        </Border.OpacityMask>

        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>    
                <RowDefinition Height="Auto"/>  
                <RowDefinition Height="*"/>     
            </Grid.RowDefinitions>

            
            <Border Grid.Row="0" Background="{DynamicResource PrimaryBrush}">
                <Grid>
                    <Button Style="{DynamicResource CloseButton}" 
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Foreground="White"
                            Margin="15,0"
                            Click="CloseButton_Click">
                        <Button.Resources>
                            
                            <Style TargetType="Button" BasedOn="{StaticResource CloseButton}">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#30FFFFFF"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>

            
            <StackPanel Grid.Row="1" Margin="0,30,0,20" HorizontalAlignment="Center">
                <Border Width="200" Height="200" HorizontalAlignment="Center">
                    <Image Source="/Presentation/Resources/Images/logo.png" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>
            </StackPanel>

            
            <StackPanel Grid.Row="2" Margin="30,0,30,30">
                
                
                <Label Content="اسم المستخدم"/>
                <TextBox x:Name="UsernameTextBox"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,16"
                         KeyDown="OnKeyDown"/>

                
                <Label Content="كلمة المرور"/>
                <Grid Height="45">
                     <PasswordBox x:Name="PasswordBox"
                                  Padding="16,0,40,0"
                                  VerticalContentAlignment="Center"
                                  KeyDown="OnKeyDown"/>
                     
                     <TextBox x:Name="VisiblePasswordBox"
                              Padding="16,0,40,0"
                              Visibility="Collapsed"
                              KeyDown="OnKeyDown"/>

                     
                     <ToggleButton x:Name="ShowPasswordToggle"
                                   Width="36"
                                   Height="36"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   Background="Transparent"
                                   BorderThickness="0"
                                   Margin="4,0,0,0"
                                   Cursor="Hand"
                                   Click="ShowPasswordToggle_Click">
                         <ToggleButton.Template>
                             <ControlTemplate TargetType="ToggleButton">
                                 <Border Background="Transparent">
                                      <Path x:Name="IconPath"
                                            Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z"
                                            Fill="{DynamicResource TextMutedBrush}"
                                            Stretch="Uniform"
                                            Width="18"
                                            Height="18"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                                 </Border>
                                 <ControlTemplate.Triggers>
                                     <Trigger Property="IsChecked" Value="True">
                                         <Setter TargetName="IconPath" Property="Fill" Value="{DynamicResource PrimaryBrush}"/>
                                         <Setter TargetName="IconPath" Property="Data" Value="M11.83,9L15,12.16C15,12.11 15,12.05 15,12A3,3 0 0,0 12,9C11.94,9 11.89,9 11.83,9M7.53,9.8L9.08,11.35C9.03,11.56 9,11.77 9,12A3,3 0 0,0 12,15C12.22,15 12.44,14.97 12.65,14.92L14.2,16.47C13.53,16.8 12.79,17 12,17A5,5 0 0,1 7,12C7,11.21 7.2,10.47 7.53,9.8M2,4.27L4.28,6.55L4.73,7C3.08,8.3 1.78,10 1,12C2.73,16.39 7,19.5 12,19.5C13.55,19.5 15.03,19.2 16.38,18.66L16.81,19.08L19.73,22L21,20.73L3.27,3L2,4.27M12,7A5,5 0 0,1 17,12C17,12.64 16.87,13.26 16.64,13.82L19.57,16.75C21.07,15.5 22.27,13.86 23,12C21.27,7.61 17,4.5 12,4.5C10.6,4.5 9.27,4.75 8.07,5.2L10.17,7.3C10.74,7.1 11.35,7 12,7Z"/>
                                     </Trigger>
                                     <Trigger Property="IsMouseOver" Value="True">
                                         <Setter TargetName="IconPath" Property="Fill" Value="{DynamicResource TextSecondaryBrush}"/>
                                     </Trigger>
                                 </ControlTemplate.Triggers>
                             </ControlTemplate>
                         </ToggleButton.Template>
                     </ToggleButton>
                </Grid>

                
                <TextBlock x:Name="ErrorLabel"
                           Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource DangerBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0"
                           MinHeight="20"/>

                
                <Button x:Name="LoginButton"
                        Content="تسجيل الدخول"
                        Style="{DynamicResource PrimaryButton}"
                        Margin="0,10,0,0"
                        Click="LoginButton_Click"/>

            </StackPanel>
        </Grid>
    </Border>
</Window>

