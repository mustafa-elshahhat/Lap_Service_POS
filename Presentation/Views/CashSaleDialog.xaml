<Window x:Class="AlJohary.ServiceHub.Presentation.Views.CashSaleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="بيع نقدي"
        SizeToContent="WidthAndHeight"
        MinWidth="450"
        MaxWidth="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FlowDirection="RightToLeft"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    
    <Border x:Name="DialogBorder" Style="{DynamicResource StandardWindowContentBorder}">
        <Border.OpacityMask>
            <VisualBrush>
                <VisualBrush.Visual>
                    <Border Background="Black" 
                            Width="{Binding ActualWidth, ElementName=DialogBorder}"
                            Height="{Binding ActualHeight, ElementName=DialogBorder}"
                            CornerRadius="12"/>
                </VisualBrush.Visual>
            </VisualBrush>
        </Border.OpacityMask>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock Text="💵" FontSize="24" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock Text="إتمام الفاتورة النقدية"
                               FontFamily="{DynamicResource MainFontSemibold}"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{DynamicResource SecondaryDarkBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Button Style="{DynamicResource CloseButton}" 
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Command="{Binding CancelCommand}"/>
            </Grid>
            
            
            <StackPanel Grid.Row="1">
                
                <Border Background="{DynamicResource WarningLightBrush}" 
                        BorderBrush="{DynamicResource WarningBrush}"
                        BorderThickness="1"
                        CornerRadius="12" 
                        Padding="20" 
                        Margin="0,0,0,28">
                    <Grid>
                        <TextBlock Text="إجمالي الفاتورة المطلوب" 
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="TotalLabel"
                                   Text="{Binding TotalAmount, Converter={StaticResource FlexibleCurrencyConverter}}"
                                   FontFamily="{DynamicResource MainFontSemibold}"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource WarningBrush}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <TextBlock Text="بيانات العميل (اختياري)" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,12"/>
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <Label Content="اسم العميل" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBox Style="{DynamicResource MainTextBox}" 
                                 Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="ادخل الاسم بالكامل"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2">
                        <Label Content="رقم الهاتف" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBox Style="{DynamicResource MainTextBox}" 
                                 Text="{Binding CustomerPhone, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="01xxxxxxxxx"/>
                    </StackPanel>
                </Grid>

                
                <Label Content="طريقة الدفع" FontWeight="Bold" Margin="0,0,0,4"/>
                <ComboBox Style="{DynamicResource MainComboBox}" 
                          ItemsSource="{Binding MethodList}"
                          SelectedItem="{Binding PaymentMethod}"
                          Height="50"
                          Margin="0,0,0,24"/>
                

            </StackPanel>
            
            
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,24,0,0">
                <Button Content="✓ تنفيذ وإصدار الفاتورة"
                        Style="{DynamicResource SecondaryButton}"
                        Width="220"
                        Height="54"
                        FontSize="16"
                        Margin="8,0"
                        IsDefault="True"
                        Command="{Binding ConfirmCommand}"/>
                <Button Content="إلغاء"
                        Style="{DynamicResource DarkButton}"
                        Width="120"
                        Height="54"
                        Margin="8,0"
                        IsCancel="True"
                        Command="{Binding CancelCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
