<Page x:Class="AlJohary.ServiceHub.Presentation.Views.SupplierTransactionDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="تفاصيل حركة المورد"
      Background="{DynamicResource BgMainBrush}"
      FlowDirection="RightToLeft"
      UseLayoutRounding="True"
      SnapsToDevicePixels="True">

    <Grid Margin="16">
        <Border Background="{DynamicResource BgCardBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="24" FlowDirection="LeftToRight">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Content="رجوع"
                            Style="{DynamicResource DarkButton}"
                            MinWidth="110"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left"
                            FlowDirection="RightToLeft"
                            Click="BackButton_Click"/>
                    <StackPanel Grid.Column="2" HorizontalAlignment="Right" FlowDirection="RightToLeft">
                        <TextBlock Text="📦 تفاصيل حركة المورد"
                                   FontFamily="{DynamicResource MainFontSemibold}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="SupplierNameText" FontSize="14" Foreground="{DynamicResource TextMutedBrush}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1" Background="{DynamicResource LightBrush}" CornerRadius="10" Padding="16" Margin="24,0,24,18">
                    <UniformGrid Columns="5">
                        <StackPanel Margin="8,0">
                            <TextBlock Text="التاريخ" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                            <TextBlock x:Name="TransactionDateText" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="8,0">
                            <TextBlock Text="المبلغ" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                            <TextBlock x:Name="AmountText" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="8,0">
                            <TextBlock Text="المدفوع" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                            <TextBlock x:Name="PaidAmountText" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="8,0">
                            <TextBlock Text="الرصيد بعد" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                            <TextBlock x:Name="BalanceAfterText" Foreground="{DynamicResource WarningDarkBrush}" FontWeight="SemiBold" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="8,0">
                            <TextBlock Text="النوع" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                            <TextBlock x:Name="TypeText" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,4,0,0"/>
                        </StackPanel>
                    </UniformGrid>
                </Border>

                <DataGrid x:Name="ItemsGrid"
                          Grid.Row="2"
                          Style="{DynamicResource MainDataGrid}"
                          Margin="24,0,24,18"
                          IsReadOnly="True"
                          AutoGenerateColumns="False"
                          FlowDirection="RightToLeft">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="اسم المنتج" Binding="{Binding ProductName}" Width="*"/>
                        <DataGridTextColumn Header="الكمية" Binding="{Binding Quantity}" Width="80" ElementStyle="{DynamicResource DataGridTextNumeric}"/>
                        <DataGridTextColumn Header="سعر الشراء" Binding="{Binding UnitPurchasePrice, Converter={StaticResource FlexibleNumberConverter}}" Width="120" ElementStyle="{DynamicResource DataGridTextNumeric}"/>
                        <DataGridTextColumn Header="الإجمالي" Binding="{Binding LineTotal, Converter={StaticResource FlexibleNumberConverter}}" Width="120" ElementStyle="{DynamicResource DataGridTextNumeric}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock x:Name="EmptyItemsText"
                           Grid.Row="3"
                           Text="لا توجد تفاصيل أصناف لهذه الحركة"
                           Foreground="{DynamicResource TextMutedBrush}"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"
                           Visibility="Collapsed"/>
            </Grid>
        </Border>
    </Grid>
</Page>
