<Window x:Class="AlJohary.ServiceHub.Presentation.Views.CustomerFormDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:AlJohary.ServiceHub.Presentation.Helpers"
        Title="بيانات العميل"
        helpers:DialogChrome.DimOwner="True"
        Width="482" MaxHeight="700"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FlowDirection="RightToLeft"
        UseLayoutRounding="True"
        ResizeMode="NoResize"
        SnapsToDevicePixels="True">

    <Border Style="{DynamicResource StandardWindowContentBorder}">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="👤" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Title}"
                               FontFamily="{DynamicResource MainFontSemibold}"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Button Style="{DynamicResource CloseButton}"
                        HorizontalAlignment="Left" VerticalAlignment="Top"
                        Command="{Binding CancelCommand}"/>
            </Grid>

            
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Label Content="اسم العميل *" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBox Style="{DynamicResource MainTextBox}"
                             Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,16"/>

                    <Label Content="رقم الهاتف" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBox Style="{DynamicResource MainTextBox}"
                             Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,16"/>

                    <Label Content="العنوان" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBox Style="{DynamicResource MainTextBox}"
                             Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,16"/>
                             
                    <Label Content="ملاحظات" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBox Style="{DynamicResource MainTextBox}"
                             Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                             Height="60"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             Margin="0,0,0,16"/>
                </StackPanel>
            </ScrollViewer>

            
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                <Button Content="حفظ"
                        Style="{DynamicResource PrimaryButton}"
                        MinWidth="120"
                        Height="45"
                        Margin="8,0"
                        IsDefault="True"
                        Command="{Binding SaveCommand}"/>
                <Button Content="إلغاء"
                        Style="{DynamicResource DarkButton}"
                        MinWidth="100"
                        Height="45"
                        Margin="8,0"
                        IsCancel="True"
                        Command="{Binding CancelCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
