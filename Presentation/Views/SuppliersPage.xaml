<Page x:Class="AlJohary.ServiceHub.Presentation.Views.SuppliersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="إدارة الموردين"
      Background="{DynamicResource BgMainBrush}"
      FlowDirection="RightToLeft"
      UseLayoutRounding="True"
      SnapsToDevicePixels="True">
    
    <Grid Margin="{DynamicResource PageContentMargin}">
        <Border Background="{DynamicResource BgCardBrush}" 
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                
                <Grid Grid.Row="0" Margin="24" FlowDirection="LeftToRight">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <WrapPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" FlowDirection="RightToLeft">
                        <Button Content="➕ إضافة مورد"
                                Style="{DynamicResource PrimaryButton}"
                                MinWidth="130"
                                Margin="4,0"
                                Command="{Binding AddSupplierCommand}"/>
                        <Button Content="📦 تسجيل شراء"
                                Style="{DynamicResource WarningButton}"
                                MinWidth="130"
                                Margin="4,0"
                                Command="{Binding AddPurchaseCommand}"/>
                        <Button Content="💰 سداد دين"
                                Style="{DynamicResource SecondaryButton}"
                                MinWidth="120"
                                Margin="4,0"
                                Command="{Binding AddPaymentCommand}"/>
                        <Button Content="🔄 عرض الكل"
                                Style="{DynamicResource DarkButton}"
                                MinWidth="140"
                                Margin="4,0"
                                Command="{Binding LoadAllCommand}"/>
                    </WrapPanel>

                    <TextBlock Grid.Column="2" 
                               Text="🏢 إدارة الموردين" 
                               FontFamily="{DynamicResource MainFontSemibold}"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Right"
                               FlowDirection="RightToLeft"
                               VerticalAlignment="Center"/>
                </Grid>
                
                
                <Grid Grid.Row="1" Margin="24,0,24,16">
                    <TextBox x:Name="SearchTextBox"
                             Style="{DynamicResource SearchTextBoxStyle}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                    
                    <StackPanel Orientation="Horizontal" IsHitTestVisible="False" Margin="12,0" VerticalAlignment="Center">
                        <TextBlock Text="🔍" FontSize="16" Margin="0,0,8,0" Foreground="{DynamicResource TextMutedBrush}"/>
                        <TextBlock Text="ابحث عن مورد..." Foreground="{DynamicResource TextMutedBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Grid>
                
                
                <Grid Grid.Row="2" Margin="24,0,24,24">
                <DataGrid x:Name="SuppliersGrid"
                          Style="{DynamicResource MainDataGrid}"
                          IsReadOnly="True"
                          ItemsSource="{Binding Suppliers}"
                          SelectedItem="{Binding SelectedSupplier}">
                    <DataGrid.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding ViewTransactionsCommand}"/>
                    </DataGrid.InputBindings>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="م" Binding="{Binding Id}" Width="60" ElementStyle="{DynamicResource DataGridTextCenter}"/>
                        <DataGridTextColumn Header="اسم المورد" Binding="{Binding Name}" Width="2*"/>
                        <DataGridTextColumn Header="الهاتف" Binding="{Binding Phone}" Width="150" ElementStyle="{DynamicResource DataGridTextCenter}"/>
                        <DataGridTextColumn Header="المديونية" Binding="{Binding TotalDebt, Converter={StaticResource FlexibleNumberConverter}}" Width="150">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridTextNumeric}">
                                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="العنوان" Binding="{Binding Address}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridTextTruncate}">
                                    <Setter Property="ToolTip" Value="{Binding Address}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                    
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="تعديل" Command="{Binding EditSupplierCommand}"/>
                            <MenuItem Header="سداد دين" Command="{Binding AddPaymentCommand}"/>
                            <MenuItem Header="عرض المعاملات" Command="{Binding ViewTransactionsCommand}"/>
                            <Separator/>
                            <MenuItem Header="حذف" Command="{Binding DeleteSupplierCommand}"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>
                <TextBlock Style="{DynamicResource DataGridEmptyState}" Text="لا يوجد موردون للعرض">
                    <TextBlock.Visibility>
                        <MultiBinding Converter="{StaticResource SearchEmptyStateConverter}" ConverterParameter="NoData">
                            <Binding Path="HasItems" ElementName="SuppliersGrid"/>
                            <Binding Path="SearchText"/>
                        </MultiBinding>
                    </TextBlock.Visibility>
                </TextBlock>
                <TextBlock Style="{DynamicResource DataGridEmptyState}" Text="لا توجد نتائج مطابقة للبحث">
                    <TextBlock.Visibility>
                        <MultiBinding Converter="{StaticResource SearchEmptyStateConverter}" ConverterParameter="NoResults">
                            <Binding Path="HasItems" ElementName="SuppliersGrid"/>
                            <Binding Path="SearchText"/>
                        </MultiBinding>
                    </TextBlock.Visibility>
                </TextBlock>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
