<Page x:Class="AlJohary.ServiceHub.Presentation.Views.EmployeesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="الموظفين"
      Background="{DynamicResource BgMainBrush}"
      FlowDirection="RightToLeft"
      UseLayoutRounding="True"
      SnapsToDevicePixels="True">

    <Grid Margin="{DynamicResource PageContentMargin}">
        <Border Background="{DynamicResource BgCardBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="24" FlowDirection="LeftToRight">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <WrapPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" FlowDirection="RightToLeft">
                        <Button Content="➕ إضافة موظف"
                                Style="{DynamicResource PrimaryButton}"
                                MinWidth="130"
                                Margin="4,0"
                                Command="{Binding AddEmployeeCommand}"/>
                        <Button Content="✏️ تعديل"
                                Style="{DynamicResource SecondaryButton}"
                                MinWidth="100"
                                Margin="4,0"
                                Command="{Binding EditEmployeeCommand}"/>
                        <Button Content="💰 صرف راتب"
                                Style="{DynamicResource WarningButton}"
                                MinWidth="120"
                                Margin="4,0"
                                Command="{Binding RegisterSalaryCommand}"/>
                        <Button Content="➖ خصم"
                                Style="{DynamicResource DarkButton}"
                                MinWidth="90"
                                Margin="4,0"
                                Command="{Binding RegisterDeductionCommand}"/>
                        <Button Content="🔄 عرض الكل"
                                Style="{DynamicResource DarkButton}"
                                MinWidth="120"
                                Margin="4,0"
                                Command="{Binding LoadAllCommand}"/>
                    </WrapPanel>

                    <StackPanel Grid.Column="2" HorizontalAlignment="Right" FlowDirection="RightToLeft">
                        <TextBlock Text="👨‍💼 إدارة الموظفين"
                                   FontFamily="{DynamicResource MainFontSemibold}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="إدارة بيانات الموظفين والرواتب والخصومات"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="24,0,24,16">
                    <TextBox x:Name="SearchTextBox"
                             Style="{DynamicResource SearchTextBoxStyle}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                    <StackPanel Orientation="Horizontal" IsHitTestVisible="False" Margin="12,0" VerticalAlignment="Center">
                        <TextBlock Text="🔍" FontSize="16" Margin="0,0,8,0" Foreground="{DynamicResource TextMutedBrush}"/>
                        <TextBlock Text="ابحث عن موظف..." Foreground="{DynamicResource TextMutedBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="2">
                <DataGrid x:Name="EmployeesGrid"
                          Style="{DynamicResource MainDataGrid}"
                          Margin="24,0,24,24"
                          ItemsSource="{Binding Employees}"
                          SelectedItem="{Binding SelectedEmployee}"
                          IsReadOnly="True">
                    <DataGrid.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding EditEmployeeCommand}"/>
                    </DataGrid.InputBindings>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="م" Binding="{Binding Id}" Width="60" ElementStyle="{DynamicResource DataGridTextCenter}"/>
                        <DataGridTextColumn Header="الاسم الكامل" Binding="{Binding FullName}" Width="2*"/>
                        <DataGridTextColumn Header="الهاتف" Binding="{Binding Phone}" Width="140" ElementStyle="{DynamicResource DataGridTextCenter}"/>
                        <DataGridTextColumn Header="المسمى الوظيفي" Binding="{Binding JobTitle}" Width="150" ElementStyle="{DynamicResource DataGridTextCenter}"/>
                        <DataGridTextColumn Header="الراتب الأساسي" Binding="{Binding BaseSalary, Converter={StaticResource FlexibleNumberConverter}}" Width="130" ElementStyle="{DynamicResource DataGridTextCenter}"/>
                        <DataGridTemplateColumn Header="الحالة" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Padding="8,3" HorizontalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource DangerLightBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource SecondaryLightBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontWeight="SemiBold" FontSize="12">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="غير نشط"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Text" Value="نشط"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource SecondaryDarkBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="ملاحظات" Binding="{Binding Notes}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridTextRight}">
                                    <Setter Property="ToolTip" Value="{Binding Notes}"/>
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>

                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="تعديل" Command="{Binding EditEmployeeCommand}"/>
                            <MenuItem Header="تفعيل / تعطيل" Command="{Binding ToggleActiveCommand}"/>
                            <Separator/>
                            <MenuItem Header="صرف راتب" Command="{Binding RegisterSalaryCommand}"/>
                            <MenuItem Header="تسجيل خصم" Command="{Binding RegisterDeductionCommand}"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>
                <TextBlock Style="{DynamicResource DataGridEmptyState}"
                           Text="لا يوجد موظفون للعرض"
                           Visibility="{Binding HasItems, ElementName=EmployeesGrid, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
