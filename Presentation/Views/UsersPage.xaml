<Page x:Class="CarPartsShopWPF.Presentation.Views.UsersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="إدارة المستخدمين"
      Background="{DynamicResource BgMainBrush}"
      FlowDirection="RightToLeft"
      UseLayoutRounding="True"
      SnapsToDevicePixels="True">
    
    <Grid Margin="16">
        <Border Background="{DynamicResource BgCardBrush}" 
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                
                <Grid Grid.Row="0" Margin="24,32,24,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="👤 إدارة المستخدمين" 
                                   FontFamily="{DynamicResource MainFontSemibold}"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="إدارة صلاحيات الموظفين والوصول للنظام" 
                                   FontSize="13" 
                                   Foreground="{DynamicResource TextMutedBrush}" 
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="2" 
                            Content="➕ إضافة مستخدم جديد"
                            Style="{DynamicResource PrimaryButton}"
                            Width="200"
                            Height="48"
                            FontFamily="{DynamicResource MainFontSemibold}"
                            Command="{Binding AddUserCommand}"/>
                </Grid>
                
                <DataGrid Grid.Row="1"
                          Style="{DynamicResource MainDataGrid}"
                          Margin="24,0,24,24"
                          ItemsSource="{Binding Users}"
                          SelectedItem="{Binding SelectedUser}"
                          IsReadOnly="True">
                    <DataGrid.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding EditUserCommand}"/>
                    </DataGrid.InputBindings>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="م" Binding="{Binding [id]}" Width="60" ElementStyle="{DynamicResource DataGridTextCenter}"/>
                        <DataGridTextColumn Header="اسم المستخدم" Binding="{Binding [username]}" Width="150" ElementStyle="{DynamicResource DataGridTextCenter}"/>
                        <DataGridTextColumn Header="الاسم الكامل" Binding="{Binding [full_name]}" Width="2*"/>
                        <DataGridTextColumn Header="الصلاحية" Binding="{Binding [role]}" Width="120" ElementStyle="{DynamicResource DataGridTextCenter}"/>
                        <DataGridTextColumn Header="حد الخصم (%)" Binding="{Binding [max_discount_percent]}" Width="120" ElementStyle="{DynamicResource DataGridTextCenter}"/>
                    </DataGrid.Columns>
                    
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="تعديل" Command="{Binding EditUserCommand}"/>
                            <MenuItem Header="تغيير كلمة المرور" Command="{Binding ChangePasswordCommand}"/>
                            <Separator/>
                            <MenuItem Header="حذف" Command="{Binding DeleteUserCommand}"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>
