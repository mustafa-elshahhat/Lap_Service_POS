<Window x:Class="CarPartsShopWPF.Presentation.Views.RegisterPurchaseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تسجيل بيع خارجي"
        Width="700"
        Height="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FlowDirection="RightToLeft"
        UseLayoutRounding="True"
        ResizeMode="NoResize"
        SnapsToDevicePixels="True">

    <Border Style="{DynamicResource StandardWindowContentBorder}">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock Text="🛒" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="تسجيل أصناف"
                               FontFamily="{DynamicResource MainFontSemibold}"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Button Style="{DynamicResource CloseButton}" 
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Command="{Binding CancelCommand}"/>
            </Grid>

            
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="50"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" Margin="4">
                                    <Label Content="اسم المنتج" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                    <TextBox Text="{Binding ProductName, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{DynamicResource MainTextBox}" Height="40"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="1" Margin="4">
                                    <Label Content="السعر (بيع)" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                    <TextBox Text="{Binding Price, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{DynamicResource MainTextBox}" Height="40"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="2" Margin="4">
                                    <Label Content="الربح" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                    <TextBox Text="{Binding Profit, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{DynamicResource MainTextBox}" Height="40"/>
                                </StackPanel>

                                <Button Grid.Column="3" 
                                        Style="{DynamicResource DangerButton}"
                                        Width="35"
                                        Height="35"
                                        VerticalAlignment="Bottom"
                                        Margin="4,0,4,4"
                                        Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="حذف">
                                    <Viewbox Width="16" Height="16">
                                        <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" 
                                              Fill="White" />
                                    </Viewbox>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="➕ إضافة منتج"
                        Style="{DynamicResource InfoButton}"
                        Width="120"
                        Height="45"
                        Command="{Binding AddItemCommand}"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="طريقة الدفع:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                    <ComboBox Width="150" Height="40"
                              ItemsSource="{Binding AvailablePaymentMethods}"
                              SelectedItem="{Binding SelectedPaymentMethod}"
                              Style="{DynamicResource MainComboBox}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="حفظ العملية"
                            Style="{DynamicResource PrimaryButton}"
                            Width="150"
                            Height="45"
                            Margin="8,0"
                            IsDefault="True"
                            Command="{Binding SaveCommand}"/>
                    <Button Content="إلغاء"
                            Style="{DynamicResource DarkButton}"
                            Width="100"
                            Height="45"
                            Margin="8,0"
                            IsCancel="True"
                            Command="{Binding CancelCommand}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
