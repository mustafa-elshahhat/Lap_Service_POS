<Window x:Class="AlJohary.ServiceHub.Presentation.Views.SupplierPurchaseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تسجيل مشتريات"
        Width="980" Height="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        FlowDirection="RightToLeft">

    <Border Style="{DynamicResource StandardWindowContentBorder}">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="📦 تسجيل مشتريات المورد"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryBrush}"
                           VerticalAlignment="Center"
                           FontFamily="{DynamicResource MainFontSemibold}"/>
                <Button Style="{DynamicResource CloseButton}"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Command="{Binding CancelCommand}"/>
            </Grid>

            <Border Grid.Row="1" Background="{DynamicResource BgCardBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,16" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="المورد" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SupplierName}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="{DynamicResource MainFontSemibold}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="المديونية الحالية: " FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding CurrentDebtText}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource WarningDarkBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <DataGrid Grid.Row="2"
                      Style="{DynamicResource DialogDataGrid}"
                      ItemsSource="{Binding Lines}"
                      SelectedItem="{Binding SelectedLine}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="False"
                      FlowDirection="RightToLeft"
                      Margin="0,0,0,16">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="اسم المنتج" Binding="{Binding ProductName, UpdateSourceTrigger=PropertyChanged}" Width="2*"/>
                    <DataGridTextColumn Header="الكمية" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                    <DataGridTextColumn Header="سعر الشراء" Binding="{Binding UnitPurchasePrice, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="120"/>
                    <DataGridTextColumn Header="الإجمالي" Binding="{Binding LineTotal, StringFormat=N2}" IsReadOnly="True" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>

            <Grid Grid.Row="3" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Label Content="قيمة المشتريات" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                    <TextBox Style="{DynamicResource MainTextBox}"
                             IsEnabled="{Binding ManualAmountEnabled}"
                             Text="{Binding ManualAmount, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="تتحدد تلقائياً عند وجود أصناف" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <Label Content="المقدم (المدفوع)" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                    <TextBox Style="{DynamicResource MainTextBox}" Text="{Binding PaidAmount, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="{Binding RemainingText}" FontSize="11" Foreground="{DynamicResource InfoBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <Label Content="طريقة دفع المقدم" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                    <ComboBox Style="{DynamicResource MainComboBox}"
                              SelectedValue="{Binding PaymentMethod, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Content">
                        <ComboBoxItem Content="نقدي"/>
                        <ComboBoxItem Content="محافظ إلكترونية"/>
                        <ComboBoxItem Content="إنستا باي"/>
                    </ComboBox>
                    <TextBlock Text="{Binding TotalAmount, StringFormat=إجمالي الفاتورة: {0:N2}}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Margin="0,6,0,0"/>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="➕ إضافة سطر" Style="{DynamicResource SecondaryButton}" Width="130" Margin="6,0" Command="{Binding AddLineCommand}"/>
                <Button Content="🗑️ حذف السطر" Style="{DynamicResource DangerButton}" Width="130" Margin="6,0" Command="{Binding RemoveLineCommand}"/>
                <Button Content="📥 استيراد CSV" Style="{DynamicResource SecondaryButton}" Width="140" Margin="6,0" Command="{Binding ImportExcelCommand}"/>
                <Button Content="📋 نسخ برومبت الذكاء الاصطناعي" Style="{DynamicResource DarkButton}" Width="240" Margin="6,0" Command="{Binding CopyAiPromptCommand}"/>
                <Button Content="حفظ" Style="{DynamicResource WarningButton}" Width="120" Margin="6,0" IsDefault="True" Command="{Binding SaveCommand}"/>
                <Button Content="إلغاء" Style="{DynamicResource DarkButton}" Width="120" Margin="6,0" IsCancel="True" Command="{Binding CancelCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
