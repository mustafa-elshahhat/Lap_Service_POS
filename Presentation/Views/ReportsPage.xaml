<Page x:Class="AlJohary.ServiceHub.Presentation.Views.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:services="clr-namespace:AlJohary.ServiceHub.Application.Services"
      Title="التقارير"
      Background="{DynamicResource BgMainBrush}"
      FlowDirection="RightToLeft"
      UseLayoutRounding="True"
      SnapsToDevicePixels="True">
    
    <Page.Resources>
        
        <DataTemplate x:Key="KpiCardTemplate">
            <Border Background="{DynamicResource BgCardBrush}" 
                    CornerRadius="12" 
                    BorderBrush="{DynamicResource BorderBrush}" 
                    BorderThickness="1" 
                    Margin="0,0,16,16" 
                    Width="240" 
                    Padding="16"
                    ToolTip="{Binding ToolTip}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" Width="48" Height="48" CornerRadius="12" Margin="0,0,12,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource PrimaryLighterBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ColorKey}" Value="Success">
                                        <Setter Property="Background" Value="{DynamicResource SecondaryLightBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ColorKey}" Value="Danger">
                                        <Setter Property="Background" Value="#15FF4D4D"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ColorKey}" Value="Warning">
                                        <Setter Property="Background" Value="{DynamicResource WarningLightBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ColorKey}" Value="Info">
                                        <Setter Property="Background" Value="{DynamicResource InfoLightBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        
                        <TextBlock Text="{Binding Icon}" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" FontFamily="{DynamicResource MainFont}"/>
                        <TextBlock Text="{Binding Value}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="{DynamicResource MainFontSemibold}" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
        
        <ItemsPanelTemplate x:Key="KpiItemsPanel">
            <WrapPanel Orientation="Horizontal"/>
        </ItemsPanelTemplate>

        <!-- KPI cards grouped by their logical section (sales/profit, net balances, in/out by
             method, salaries, maintenance, supplier/expenses) for visual grouping on reports. -->
        <CollectionViewSource x:Key="GroupedKpiCards" Source="{Binding KpiCards}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="Group"/>
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>
    </Page.Resources>
    
    <Grid Margin="16" x:Name="ReportsRoot">
        
        <Grid.OpacityMask>
            <VisualBrush>
                <VisualBrush.Visual>
                    <Border Background="Black" 
                            Width="{Binding ActualWidth, ElementName=ReportsRoot}"
                            Height="{Binding ActualHeight, ElementName=ReportsRoot}"
                            CornerRadius="12"/>
                </VisualBrush.Visual>
            </VisualBrush>
        </Grid.OpacityMask>

        <Border Background="{DynamicResource BgCardBrush}" 
                BorderBrush="{DynamicResource BorderBrush}" 
                BorderThickness="1" 
                CornerRadius="12"
                ClipToBounds="True">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                
                <Border Grid.Column="0" Background="{DynamicResource BgSidebarBrush}" BorderBrush="{DynamicResource BorderDarkBrush}" BorderThickness="0,0,1,0">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Padding="24,40,24,24">
                            <StackPanel>
                                <TextBlock Text="📊 التقارير" 
                                           FontSize="22" 
                                           FontWeight="Bold" 
                                           Foreground="{DynamicResource TextLightBrush}" 
                                           HorizontalAlignment="Left"
                                           FontFamily="{DynamicResource MainFontSemibold}"/>
                                <TextBlock Text="تحليل أداء النشاط المالي والمخزون" 
                                           FontSize="11" 
                                           Foreground="{DynamicResource TextMutedBrush}" 
                                           Margin="0,6,0,0" 
                                           TextWrapping="Wrap" 
                                           HorizontalAlignment="Left"
                                           Opacity="0.7"/>
                            </StackPanel>
                        </Border>
                        
                        <ScrollViewer VerticalScrollBarVisibility="Hidden" Margin="0,0,0,20">
                            <StackPanel Margin="0,12">
                                <RadioButton Content="📅 التقرير اليومي" Style="{DynamicResource TabRadioButton}" IsChecked="True" Command="{Binding LoadReportCommand}" CommandParameter="Daily"/>
                                <RadioButton Content="📆 التقرير الشهري" Style="{DynamicResource TabRadioButton}" Command="{Binding LoadReportCommand}" CommandParameter="Monthly"/>

                                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Margin="24,12" Opacity="0.1"/>

                                <RadioButton Content="🧮 العمليات المالية اليومية" Style="{DynamicResource TabRadioButton}" Command="{Binding LoadReportCommand}" CommandParameter="DailyOperations"/>
                                <RadioButton Content="🧾 العمليات المالية الشهرية" Style="{DynamicResource TabRadioButton}" Command="{Binding LoadReportCommand}" CommandParameter="MonthlyOperations"/>

                                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Margin="24,12" Opacity="0.1"/>

                                <RadioButton Content="📦 تقرير المخزون" Style="{DynamicResource TabRadioButton}" Command="{Binding LoadReportCommand}" CommandParameter="Inventory"/>
                                <RadioButton Content="↩️ تقرير المرتجعات" Style="{DynamicResource TabRadioButton}" Command="{Binding LoadReportCommand}" CommandParameter="Returns"/>
                                
                                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Margin="24,12" Opacity="0.1"/>
                                
                                <RadioButton Content=" ديون الموردين" Style="{DynamicResource TabRadioButton}" Command="{Binding LoadReportCommand}" CommandParameter="Suppliers"/>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
                
                <Border Grid.Column="1" Background="{DynamicResource BgMainBrush}" Padding="32">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,32">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding ReportTitle}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding ReportSubtitle}" FontSize="14" Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
         
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="📥 تصدير CSV" Style="{DynamicResource PrimaryButton}" Width="130" Command="{Binding ExportCommand}" Margin="0,0,12,0"/>
                                <Button x:Name="PrintButton" Content="🖨️ طباعة التقرير" Style="{DynamicResource PrimaryButton}" Width="160" Command="{Binding PrintReportCommand}"/>
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="1" Visibility="{Binding DateFilterVisibility}" Background="Transparent" Margin="0,0,0,16">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="من تاريخ" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <DatePicker SelectedDate="{Binding FilterStartDate, Mode=TwoWay}" FontSize="13" VerticalAlignment="Center" Margin="0,0,24,0"/>
                                <TextBlock Text="إلى تاريخ" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <DatePicker SelectedDate="{Binding FilterEndDate, Mode=TwoWay}" FontSize="13" VerticalAlignment="Center" Margin="0,0,24,0"/>
                                <TextBlock Text="{Binding DateValidationMessage}" FontSize="12" Foreground="Red" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DateValidationMessage}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
          
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding KpiVisibility}" Margin="0,0,0,16">
                            <ItemsControl ItemsSource="{Binding Source={StaticResource GroupedKpiCards}}"
                                          ItemTemplate="{DynamicResource KpiCardTemplate}">
                                <ItemsControl.GroupStyle>
                                    <GroupStyle>
                                        <GroupStyle.Panel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </GroupStyle.Panel>
                                        <GroupStyle.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="14"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           Margin="0,12,0,8"
                                                           FontFamily="{DynamicResource MainFontSemibold}"/>
                                            </DataTemplate>
                                        </GroupStyle.HeaderTemplate>
                                    </GroupStyle>
                                </ItemsControl.GroupStyle>
                            </ItemsControl>
                        </ScrollViewer>

                        <Border Grid.Row="3"
                                Visibility="{Binding OperationsVisibility}"
                                Background="{DynamicResource BgCardBrush}"
                                CornerRadius="16"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                Padding="24">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.05" Color="#000000"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
         
                                <TextBlock Text="{Binding DetailHeader}" 
                                           FontSize="20" 
                                           FontWeight="Bold" 
                                           Foreground="{DynamicResource TextPrimaryBrush}" 
                                           Margin="0,0,0,24"
                                           FontFamily="{DynamicResource MainFontSemibold}"/>
                                
                                <DataGrid x:Name="ReportDataGrid" 
                                          Grid.Row="1" 
                                          Style="{DynamicResource MainDataGrid}"
                                          ItemsSource="{Binding ReportData}"
                                          IsReadOnly="True"
                                          BorderThickness="0"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
