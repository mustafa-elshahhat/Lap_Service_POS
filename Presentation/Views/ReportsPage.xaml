<Page x:Class="AlJohary.ServiceHub.Presentation.Views.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:services="clr-namespace:AlJohary.ServiceHub.Application.Services"
       xmlns:behaviors="clr-namespace:AlJohary.ServiceHub.Presentation.Behaviors"
      Title="التقارير"
      Background="{DynamicResource BgMainBrush}"
      FlowDirection="RightToLeft"
      UseLayoutRounding="True"
      SnapsToDevicePixels="True">
    
    <Page.Resources>
        
        <DataTemplate x:Key="KpiCardTemplate">
            <Border Background="{DynamicResource BgCardBrush}"
                    CornerRadius="12"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Margin="0,0,12,12"
                    Width="220"
                    MinHeight="78"
                    Padding="14"
                    ToolTip="{Binding ToolTip}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="44" Height="44" CornerRadius="10" Margin="0,0,12,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource PrimaryLighterBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ColorKey}" Value="Success">
                                        <Setter Property="Background" Value="{DynamicResource SecondaryLightBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ColorKey}" Value="Danger">
                                        <Setter Property="Background" Value="#15FF4D4D"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ColorKey}" Value="Warning">
                                        <Setter Property="Background" Value="{DynamicResource WarningLightBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ColorKey}" Value="Info">
                                        <Setter Property="Background" Value="{DynamicResource InfoLightBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        
                        <TextBlock Text="{Binding Icon}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" FontFamily="{DynamicResource MainFont}"/>
                        <TextBlock Text="{Binding Value}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="{DynamicResource MainFontSemibold}" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
        
        <ItemsPanelTemplate x:Key="KpiItemsPanel">
            <WrapPanel Orientation="Horizontal"/>
        </ItemsPanelTemplate>

        <!-- KPI cards grouped by their logical section (sales/profit, net balances, in/out by
             method, salaries, maintenance, supplier/expenses) for visual grouping on reports. -->
        <CollectionViewSource x:Key="GroupedKpiCards" Source="{Binding KpiCards}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="Group"/>
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>
    </Page.Resources>
    
    <Grid Margin="16" x:Name="ReportsRoot">
        
        <Grid.OpacityMask>
            <VisualBrush>
                <VisualBrush.Visual>
                    <Border Background="Black" 
                            Width="{Binding ActualWidth, ElementName=ReportsRoot}"
                            Height="{Binding ActualHeight, ElementName=ReportsRoot}"
                            CornerRadius="12"/>
                </VisualBrush.Visual>
            </VisualBrush>
        </Grid.OpacityMask>

        <Border Background="{DynamicResource BgCardBrush}" 
                BorderBrush="{DynamicResource BorderBrush}" 
                BorderThickness="1" 
                CornerRadius="12"
                ClipToBounds="True">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                
                <Border Grid.Column="0" Background="{DynamicResource BgSidebarBrush}" BorderBrush="{DynamicResource BorderDarkBrush}" BorderThickness="0,0,1,0">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Padding="24,40,24,24">
                            <StackPanel>
                                <TextBlock Text="📊 التقارير" 
                                           FontSize="22" 
                                           FontWeight="Bold" 
                                           Foreground="{DynamicResource TextLightBrush}" 
                                           HorizontalAlignment="Left"
                                           FontFamily="{DynamicResource MainFontSemibold}"/>
                                <TextBlock Text="تحليل أداء النشاط المالي والمخزون" 
                                           FontSize="11" 
                                           Foreground="{DynamicResource TextMutedBrush}" 
                                           Margin="0,6,0,0" 
                                           TextWrapping="Wrap" 
                                           HorizontalAlignment="Left"
                                           Opacity="0.7"/>
                            </StackPanel>
                        </Border>
                        
                        <ScrollViewer VerticalScrollBarVisibility="Disabled" Margin="0,0,0,20">
                            <StackPanel Margin="0,12">
                                <RadioButton Content="📅 التقرير اليومي" Style="{DynamicResource TabRadioButton}" IsChecked="True" Command="{Binding LoadReportCommand}" CommandParameter="Daily"/>
                                <RadioButton Content="📆 التقرير الشهري" Style="{DynamicResource TabRadioButton}" Command="{Binding LoadReportCommand}" CommandParameter="Monthly"/>

                                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Margin="24,12" Opacity="0.1"/>

                                <RadioButton Content="🧮 العمليات المالية اليومية" Style="{DynamicResource TabRadioButton}" Command="{Binding LoadReportCommand}" CommandParameter="DailyOperations"/>
                                <RadioButton Content="🧾 العمليات المالية الشهرية" Style="{DynamicResource TabRadioButton}" Command="{Binding LoadReportCommand}" CommandParameter="MonthlyOperations"/>

                                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Margin="24,12" Opacity="0.1"/>

                                <RadioButton Content="📦 تقرير المخزون" Style="{DynamicResource TabRadioButton}" Command="{Binding LoadReportCommand}" CommandParameter="Inventory"/>
                                <RadioButton Content="↩️ تقرير المرتجعات" Style="{DynamicResource TabRadioButton}" Command="{Binding LoadReportCommand}" CommandParameter="Returns"/>
                                
                                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Margin="24,12" Opacity="0.1"/>
                                
                                <RadioButton Content=" ديون الموردين" Style="{DynamicResource TabRadioButton}" Command="{Binding LoadReportCommand}" CommandParameter="Suppliers"/>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
                
                <Border Grid.Column="1" Background="{DynamicResource BgMainBrush}" Padding="28,24,28,24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header: report title/subtitle + export/print actions -->
                        <Grid Grid.Row="0" Margin="0,0,0,18" FlowDirection="LeftToRight">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" FlowDirection="RightToLeft">
                                <Button Content="📥 تصدير CSV" Style="{DynamicResource PrimaryButton}" MinWidth="130" Command="{Binding ExportCommand}" Margin="0,0,12,0"/>
                                <Button x:Name="PrintButton" Content="🖨️ طباعة التقرير" Style="{DynamicResource PrimaryButton}" MinWidth="160" Command="{Binding PrintReportCommand}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" FlowDirection="RightToLeft">
                                <TextBlock Text="{Binding ReportTitle}" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding ReportSubtitle}" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>

                        <!-- Filter bar: grouped date pickers in a connected, aligned container -->
                        <Border Grid.Row="1"
                                Visibility="{Binding DateFilterVisibility}"
                                Background="{DynamicResource BgCardBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="16,10"
                                Margin="0,0,0,18"
                                HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="🗓️ الفترة:" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                <TextBlock Text="من" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <DatePicker SelectedDate="{Binding FilterStartDate, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,20,0"/>
                                <TextBlock Text="إلى" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <DatePicker SelectedDate="{Binding FilterEndDate, Mode=TwoWay}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding DateValidationMessage}" FontSize="12" Foreground="Red" VerticalAlignment="Center" Margin="16,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DateValidationMessage}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Single main scroll area: grouped KPI cards and/or the details grid.
                             Cards-only reports fill and scroll here; operations pages show the
                             grid (height-capped to the viewport so it keeps virtualizing and
                             does not force an oversized page). -->
                        <ScrollViewer Grid.Row="2" x:Name="MainScroll"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="0,0,4,0">
                            <StackPanel>
                                <ItemsControl Visibility="{Binding KpiVisibility}"
                                              ItemsSource="{Binding Source={StaticResource GroupedKpiCards}}"
                                              ItemTemplate="{DynamicResource KpiCardTemplate}">
                                    <ItemsControl.GroupStyle>
                                        <GroupStyle>
                                            <GroupStyle.Panel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </GroupStyle.Panel>
                                            <GroupStyle.HeaderTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,10">
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Name}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>
                                                        <Border Width="4" Height="16" CornerRadius="2" Background="{DynamicResource PrimaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="14"
                                                                   FontWeight="Bold"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   VerticalAlignment="Center"
                                                                   FontFamily="{DynamicResource MainFontSemibold}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </GroupStyle.HeaderTemplate>
                                        </GroupStyle>
                                    </ItemsControl.GroupStyle>
                                </ItemsControl>

                                <Border Visibility="{Binding OperationsVisibility}"
                                        MaxHeight="{Binding ViewportHeight, ElementName=MainScroll}"
                                        Background="{DynamicResource BgCardBrush}"
                                        CornerRadius="16"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        Padding="20">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.05" Color="#000000"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Text="{Binding DetailHeader}"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Margin="0,0,0,16"
                                                   FontFamily="{DynamicResource MainFontSemibold}"/>

                                         <DataGrid x:Name="ReportDataGrid"
                                                   Grid.Row="1"
                                                   Style="{DynamicResource MainDataGrid}"
                                                   ItemsSource="{Binding ReportData}"
                                                   IsReadOnly="True"
                                                   BorderThickness="0"
                                                   behaviors:DataGridScrollBehavior.ForwardMouseWheelToParent="True"
                                                   ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                   ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                        </DataGrid>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
