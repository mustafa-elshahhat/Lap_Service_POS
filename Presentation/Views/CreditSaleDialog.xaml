<Window x:Class="CarPartsShopWPF.Presentation.Views.CreditSaleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="بيع آجل"
        Width="500"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FlowDirection="RightToLeft"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        KeyDown="Window_KeyDown">
    
    <Border Style="{DynamicResource StandardWindowContentBorder}">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock Text="📝" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="بيانات البيع الآجل"
                               FontFamily="{DynamicResource MainFontSemibold}"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{DynamicResource WarningBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Button Style="{DynamicResource CloseButton}" 
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Command="{Binding CancelCommand}"/>
            </Grid>
            
            
            <StackPanel Grid.Row="1">
                
                
                <Border Background="{DynamicResource WarningLightBrush}" 
                        BorderBrush="{DynamicResource WarningBrush}"
                        BorderThickness="1"
                        CornerRadius="12" 
                        Padding="20" 
                        Margin="0,0,0,28">
                    <Grid>
                        <TextBlock Text="إجمالي الفاتورة المطلوب" 
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="TotalLabel"
                                   Text="{Binding TotalAmountText}"
                                   FontFamily="{DynamicResource MainFontSemibold}"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource WarningBrush}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                
                <TextBlock Text="بيانات العميل (إلزامي لضمان الحقوق)" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource WarningBrush}" Margin="0,0,0,12"/>
                
                
                <Label Content="اسم العميل *" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBox x:Name="CustomerNameTextBox"
                             Grid.Column="0"
                             Style="{DynamicResource MainTextBox}"
                             Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}"/>
                             
                    <Button Grid.Column="1"
                            Content="🔍 بحث"
                            Margin="8,0,0,0"
                            Padding="12,0"
                            Height="42"
                            Style="{DynamicResource InfoButton}"
                            Command="{Binding SelectCustomerCommand}"
                            ToolTip="بحث واختيار من العملاء المسجلين"/>
                </Grid>
                
                
                <Label Content="رقم الهاتف *" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBox x:Name="CustomerPhoneTextBox"
                         Style="{DynamicResource MainTextBox}"
                         Text="{Binding CustomerPhone, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,16"/>
                
                <Grid Margin="0,0,0,12">
                   <Grid.ColumnDefinitions>
                       <ColumnDefinition Width="*"/>
                       <ColumnDefinition Width="20"/>
                       <ColumnDefinition Width="*"/>
                   </Grid.ColumnDefinitions>
                   
                   <StackPanel Grid.Column="0">
                       
                       <Label Content="المبلغ المدفوع (مقدم)" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                       <TextBox x:Name="PaidAmountTextBox"
                                Style="{DynamicResource MainTextBox}"
                                Text="{Binding PaidAmountText, UpdateSourceTrigger=PropertyChanged}"/>
                   </StackPanel>

                   <StackPanel Grid.Column="2">
                       
                       <Label Content="طريقة سداد المقدم" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                       <ComboBox x:Name="PaymentMethodComboBox"
                                 Style="{DynamicResource MainComboBox}"
                                 ItemsSource="{Binding PaymentMethodsList}"
                                 SelectedItem="{Binding PaymentMethod}"/>
                   </StackPanel>
                </Grid>
            </StackPanel>
            
            
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,32,0,12">
                <Button Content="تأكيد وحفظ الفاتورة"
                        Style="{DynamicResource WarningButton}"
                        Width="180"
                        Height="50"
                        Margin="8,0"
                        FontFamily="{DynamicResource MainFontSemibold}"
                        IsDefault="True"
                        Command="{Binding ConfirmCommand}"/>
                <Button Content="إلغاء"
                        Style="{DynamicResource DarkButton}"
                        Width="120"
                        Height="50"
                        Margin="8,0"
                        IsCancel="True"
                        Command="{Binding CancelCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

