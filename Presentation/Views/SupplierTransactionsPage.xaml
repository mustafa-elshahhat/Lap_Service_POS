<Page x:Class="AlJohary.ServiceHub.Presentation.Views.SupplierTransactionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="حركات المورد"
      Background="{DynamicResource BgMainBrush}"
      FlowDirection="RightToLeft"
      UseLayoutRounding="True"
      SnapsToDevicePixels="True">

    <Grid Margin="16">
        <Border Background="{DynamicResource BgCardBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="24" FlowDirection="LeftToRight">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <WrapPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" FlowDirection="RightToLeft">
                        <Button Content="🖨️ طباعة كشف حساب"
                                Style="{DynamicResource PrimaryButton}"
                                MinWidth="170"
                                Margin="4,0"
                                Click="PrintReport_Click"/>
                        <Button Content="رجوع"
                                Style="{DynamicResource DarkButton}"
                                MinWidth="110"
                                Margin="4,0"
                                Click="BackButton_Click"/>
                    </WrapPanel>

                    <StackPanel Grid.Column="2" HorizontalAlignment="Right" FlowDirection="RightToLeft">
                        <TextBlock Text="📜 حركات المورد"
                                   FontFamily="{DynamicResource MainFontSemibold}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="SupplierNameText"
                                   FontSize="14"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1"
                        Background="{DynamicResource InfoLightBrush}"
                        BorderBrush="{DynamicResource InfoBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="16"
                        Margin="24,0,24,16">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="المديونية الحالية: " FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="CurrentDebtText" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource WarningDarkBrush}"/>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="2" Margin="24,0,24,24">
                <DataGrid x:Name="TransactionsGrid"
                          Style="{DynamicResource MainDataGrid}"
                          IsReadOnly="True"
                          AutoGenerateColumns="False"
                          MouseDoubleClick="TransactionsGrid_MouseDoubleClick"
                          FlowDirection="RightToLeft">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding [id]}" Width="60" ElementStyle="{DynamicResource DataGridTextCenter}"/>
                        <DataGridTextColumn Header="التاريخ" Binding="{Binding [transaction_date]}" Width="140" ElementStyle="{DynamicResource DataGridTextCenter}"/>
                        <DataGridTextColumn Header="النوع" Binding="{Binding [transaction_type_ar]}" Width="120"/>
                        <DataGridTextColumn Header="المبلغ" Binding="{Binding [amount], Converter={StaticResource FlexibleNumberConverter}}" Width="120" ElementStyle="{DynamicResource DataGridTextCenter}"/>
                        <DataGridTextColumn Header="المدفوع" Binding="{Binding [paid_amount], Converter={StaticResource FlexibleNumberConverter}}" Width="120" ElementStyle="{DynamicResource DataGridTextCenter}"/>
                        <DataGridTextColumn Header="الرصيد بعد" Binding="{Binding [balance_after], Converter={StaticResource FlexibleNumberConverter}}" Width="120" ElementStyle="{DynamicResource DataGridTextCenter}"/>
                        <DataGridTextColumn Header="بواسطة" Binding="{Binding [created_by]}" Width="*"/>
                        <DataGridTemplateColumn Header="التفاصيل" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="عرض"
                                            Style="{DynamicResource SecondaryButton}"
                                            Padding="8,2"
                                            Click="DetailsButton_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
                <TextBlock Style="{DynamicResource DataGridEmptyState}"
                           Text="لا توجد حركات للعرض"
                           Visibility="{Binding HasItems, ElementName=TransactionsGrid, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                </Grid>

                <TextBlock Grid.Row="3"
                           Text="انقر مرتين على أي حركة لعرض تفاصيلها"
                           Foreground="{DynamicResource TextMutedBrush}"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,18"/>
            </Grid>
        </Border>
    </Grid>
</Page>
