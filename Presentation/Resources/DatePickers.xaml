<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Geometry x:Key="DatePickerCalendarIconGeometry">M5,5.5 H19 A2,2 0 0 1 21,7.5 V19 A2,2 0 0 1 19,21 H5 A2,2 0 0 1 3,19 V7.5 A2,2 0 0 1 5,5.5 M3,10 H21 M8,3 V7 M16,3 V7 M7,14 H9 M12,14 H14 M17,14 H19 M7,17 H9 M12,17 H14</Geometry>

    <Style x:Key="DatePickerTextBoxStyle" TargetType="DatePickerTextBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{DynamicResource MainFont}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="NumberSubstitution.Substitution" Value="European"/>
        <Setter Property="Padding" Value="14,0,12,0"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="DatePickerDropDownButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="IconSurface"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            CornerRadius="7"
                            SnapsToDevicePixels="True">
                        <Viewbox Width="17" Height="17"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center">
                            <Path x:Name="Icon"
                                  Data="{StaticResource DatePickerCalendarIconGeometry}"
                                  Fill="Transparent"
                                  Stroke="{TemplateBinding Foreground}"
                                  StrokeThickness="1.65"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"/>
                        </Viewbox>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="IconSurface" Property="Background" Value="{DynamicResource PrimaryLighterBrush}"/>
                            <Setter TargetName="IconSurface" Property="BorderBrush" Value="{DynamicResource PrimaryLightBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="IconSurface" Property="Background" Value="{DynamicResource PrimaryLightBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryDarkBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Cursor" Value="Arrow"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
                            <Setter TargetName="IconSurface" Property="Opacity" Value="0.6"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ModernCalendarDayButtonStyle" TargetType="CalendarDayButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{DynamicResource MainFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="MinWidth" Value="31"/>
        <Setter Property="MinHeight" Value="29"/>
        <Setter Property="Margin" Value="1"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CalendarDayButton">
                    <Border x:Name="DayChrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="7"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="DayChrome" Property="Background" Value="{DynamicResource PrimaryLighterBrush}"/>
                            <Setter TargetName="DayChrome" Property="BorderBrush" Value="{DynamicResource PrimaryLightBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryDarkBrush}"/>
                        </Trigger>
                        <Trigger Property="IsToday" Value="True">
                            <Setter TargetName="DayChrome" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryDarkBrush}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="DayChrome" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                            <Setter TargetName="DayChrome" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource WhiteBrush}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Trigger>
                        <Trigger Property="IsInactive" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
                            <Setter Property="Opacity" Value="0.58"/>
                        </Trigger>
                        <Trigger Property="IsBlackedOut" Value="True">
                            <Setter Property="Opacity" Value="0.32"/>
                            <Setter Property="IsHitTestVisible" Value="False"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
                            <Setter Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ModernCalendarButtonStyle" TargetType="CalendarButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{DynamicResource MainFontSemibold}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="MinWidth" Value="58"/>
        <Setter Property="MinHeight" Value="34"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CalendarButton">
                    <Border x:Name="ButtonChrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource PrimaryLighterBrush}"/>
                            <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{DynamicResource PrimaryLightBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryDarkBrush}"/>
                        </Trigger>
                        <Trigger Property="IsInactive" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
                            <Setter Property="Opacity" Value="0.55"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ModernDatePickerCalendarItemStyle" TargetType="CalendarItem">
        <Setter Property="Background" Value="{DynamicResource BgCardBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style x:Key="ModernDatePickerCalendarStyle" TargetType="Calendar">
        <Setter Property="Background" Value="{DynamicResource BgCardBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontFamily" Value="{DynamicResource MainFont}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="CalendarDayButtonStyle" Value="{StaticResource ModernCalendarDayButtonStyle}"/>
        <Setter Property="CalendarButtonStyle" Value="{StaticResource ModernCalendarButtonStyle}"/>
        <Setter Property="CalendarItemStyle" Value="{StaticResource ModernDatePickerCalendarItemStyle}"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <Style x:Key="ModernDatePickerStyle" TargetType="DatePicker">
        <Setter Property="Background" Value="{DynamicResource BgInputBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{DynamicResource MainFont}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Height" Value="45"/>
        <Setter Property="MinWidth" Value="142"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="CalendarStyle" Value="{StaticResource ModernDatePickerCalendarStyle}"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DatePicker">
                    <Grid x:Name="PART_Root"
                          FlowDirection="{TemplateBinding FlowDirection}"
                          SnapsToDevicePixels="True">
                        <Border x:Name="FocusGlow"
                                Margin="-2"
                                Background="Transparent"
                                BorderBrush="{DynamicResource PrimaryLightBrush}"
                                BorderThickness="2"
                                CornerRadius="10"
                                Opacity="0"
                                IsHitTestVisible="False"/>

                        <Border x:Name="InputChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <Grid Margin="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <DatePickerTextBox x:Name="PART_TextBox"
                                                   Grid.Column="0"
                                                   Background="Transparent"
                                                   Foreground="{TemplateBinding Foreground}"
                                                   FontFamily="{TemplateBinding FontFamily}"
                                                   FontSize="{TemplateBinding FontSize}"
                                                   FlowDirection="{TemplateBinding FlowDirection}"
                                                   Style="{StaticResource DatePickerTextBoxStyle}"
                                                   VerticalAlignment="Stretch"
                                                   VerticalContentAlignment="Center"/>

                                <Button x:Name="PART_Button"
                                        Grid.Column="1"
                                        Style="{StaticResource DatePickerDropDownButtonStyle}"
                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                        Margin="4,0"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               Focusable="False"
                               IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                               Placement="Bottom"
                               PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                               PopupAnimation="Fade"
                               StaysOpen="False">
                            <Border Background="{DynamicResource BgCardBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Margin="0,6,0,10"
                                    Padding="6"
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    FlowDirection="{Binding FlowDirection, RelativeSource={RelativeSource TemplatedParent}}"
                                    SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect Color="#1F2937" Opacity="0.16" BlurRadius="18" ShadowDepth="4"/>
                                </Border.Effect>
                                <Calendar x:Name="PART_Calendar"
                                          Style="{Binding CalendarStyle, RelativeSource={RelativeSource TemplatedParent}}"
                                          BorderThickness="0"
                                          FlowDirection="{Binding FlowDirection, RelativeSource={RelativeSource TemplatedParent}}"/>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="InputChrome" Property="BorderBrush" Value="{DynamicResource BorderDarkBrush}"/>
                            <Setter TargetName="InputChrome" Property="Background" Value="{DynamicResource BgCardBrush}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="InputChrome" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            <Setter TargetName="FocusGlow" Property="Opacity" Value="1"/>
                            <Setter TargetName="PART_Button" Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="InputChrome" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            <Setter TargetName="FocusGlow" Property="Opacity" Value="1"/>
                            <Setter TargetName="PART_Button" Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="InputChrome" Property="Background" Value="{DynamicResource BgMainBrush}"/>
                            <Setter TargetName="InputChrome" Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                            <Setter TargetName="InputChrome" Property="Opacity" Value="0.74"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
                        </Trigger>
                        <Trigger Property="Validation.HasError" Value="True">
                            <Setter TargetName="InputChrome" Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
                            <Setter TargetName="FocusGlow" Property="BorderBrush" Value="{DynamicResource DangerLightBrush}"/>
                            <Setter TargetName="FocusGlow" Property="Opacity" Value="1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="DatePicker" BasedOn="{StaticResource ModernDatePickerStyle}"/>

</ResourceDictionary>
