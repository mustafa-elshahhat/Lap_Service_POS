<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    
    
    
    
    <Color x:Key="PrimaryColor">#2563EB</Color>
    <Color x:Key="PrimaryDarkColor">#1D4ED8</Color>
    <Color x:Key="PrimaryLightColor">#DBEAFE</Color>
    <Color x:Key="PrimaryLighterColor">#EFF6FF</Color>
    
    
    <Color x:Key="SecondaryColor">#10B981</Color>
    <Color x:Key="SecondaryDarkColor">#059669</Color>
    <Color x:Key="SecondaryLightColor">#D1FAE5</Color>
    
    
    <Color x:Key="DangerColor">#EF4444</Color>
    <Color x:Key="DangerDarkColor">#DC2626</Color>
    <Color x:Key="DangerLightColor">#FEE2E2</Color>
    
    
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="WarningDarkColor">#D97706</Color>
    <Color x:Key="WarningLightColor">#FEF3C7</Color>
    
    
    <Color x:Key="InfoColor">#0EA5E9</Color>
    <Color x:Key="InfoDarkColor">#0284C7</Color>
    <Color x:Key="InfoLightColor">#E0F2FE</Color>
    
    
    <Color x:Key="DarkColor">#1F2937</Color>         
    <Color x:Key="DarkHoverColor">#374151</Color>    
    <Color x:Key="LightColor">#F9FAFB</Color>        
    <Color x:Key="WhiteColor">#FFFFFF</Color>
    <Color x:Key="BlackColor">#000000</Color>
    
    
    <Color x:Key="BgMainColor">#F3F4F6</Color>       
    <Color x:Key="BgCardColor">#FFFFFF</Color>       
    <Color x:Key="BgSidebarColor">#111827</Color>    
    <Color x:Key="BgInputColor">#FFFFFF</Color>
    
    
    <Color x:Key="TextPrimaryColor">#1F2937</Color>   
    <Color x:Key="TextSecondaryColor">#4B5563</Color> 
    <Color x:Key="TextMutedColor">#9CA3AF</Color>     
    <Color x:Key="TextLightColor">#F9FAFB</Color>     
    
    
    <Color x:Key="BorderColor">#E5E7EB</Color>
    <Color x:Key="BorderDarkColor">#D1D5DB</Color>
    <Color x:Key="BorderFocusColor">#3B82F6</Color>

    
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}"/>
    <SolidColorBrush x:Key="PrimaryLighterBrush" Color="{StaticResource PrimaryLighterColor}"/>
    
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="SecondaryDarkBrush" Color="{StaticResource SecondaryDarkColor}"/>
    <SolidColorBrush x:Key="SecondaryLightBrush" Color="{StaticResource SecondaryLightColor}"/>
    
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="DangerDarkBrush" Color="{StaticResource DangerDarkColor}"/>
    <SolidColorBrush x:Key="DangerLightBrush" Color="{StaticResource DangerLightColor}"/>
    
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="WarningDarkBrush" Color="{StaticResource WarningDarkColor}"/>
    <SolidColorBrush x:Key="WarningLightBrush" Color="{StaticResource WarningLightColor}"/>
    
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>
    <SolidColorBrush x:Key="InfoDarkBrush" Color="{StaticResource InfoDarkColor}"/>
    <SolidColorBrush x:Key="InfoLightBrush" Color="{StaticResource InfoLightColor}"/>
    
    <SolidColorBrush x:Key="DarkBrush" Color="{StaticResource DarkColor}"/>
    <SolidColorBrush x:Key="DarkHoverBrush" Color="{StaticResource DarkHoverColor}"/>
    <SolidColorBrush x:Key="LightBrush" Color="{StaticResource LightColor}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource WhiteColor}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource BlackColor}"/>
    
    <SolidColorBrush x:Key="BgMainBrush" Color="{StaticResource BgMainColor}"/>
    <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCardColor}"/>
    <SolidColorBrush x:Key="BgSidebarBrush" Color="{StaticResource BgSidebarColor}"/>
    <SolidColorBrush x:Key="BgInputBrush" Color="{StaticResource BgInputColor}"/>
    
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="TextLightBrush" Color="{StaticResource TextLightColor}"/>
    
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderDarkBrush" Color="{StaticResource BorderDarkColor}"/>
    <SolidColorBrush x:Key="BorderFocusBrush" Color="{StaticResource BorderFocusColor}"/>
</ResourceDictionary>
